{"id": "com.claudroid.habits", "name": "Habit Tracker", "desc": "Track daily habits with streaks and a 30-day history grid. Add up to 10 custom habits. Saved locally.", "icon": "✅", "color": "#0a1a10", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box}body{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}.top{background:#0e1117;border-bottom:1px solid #1c2333;padding:12px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0}.top-title{font-size:16px;font-weight:800;flex:1}.date-lbl{font-size:12px;color:#6b7a99;font-weight:600}.add-btn{background:#34d399;border:none;color:#07090f;border-radius:10px;padding:7px 13px;font-size:13px;font-weight:800;cursor:pointer;font-family:inherit}.list{flex:1;overflow-y:auto;padding:12px 14px}.hcard{background:#0e1117;border:1px solid #1c2333;border-radius:18px;padding:14px 16px;margin-bottom:10px}.hc-top{display:flex;align-items:center;gap:12px;margin-bottom:10px}.hc-emoji{font-size:26px;flex-shrink:0}.hc-info{flex:1}.hc-name{font-size:15px;font-weight:800}.hc-streak{font-size:11px;color:#6b7a99;margin-top:2px;font-weight:600}.hc-del{background:none;border:none;color:#3d4a63;font-size:16px;cursor:pointer;padding:4px}.hcheck{width:36px;height:36px;border-radius:18px;border:2.5px solid #2d3748;background:none;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}.hcheck.done{background:#34d399;border-color:#34d399;color:#07090f}.grid{display:flex;gap:3px}.gc{width:15px;height:15px;border-radius:4px;background:#1c2333;flex-shrink:0;transition:background .2s}.gc.done{background:#34d399}.gc.today{outline:2px solid #4f8ef7;outline-offset:1px}.sheet{position:fixed;inset:0;background:rgba(0,0,0,.7);display:flex;align-items:flex-end;z-index:100}.sheet-panel{background:#0e1117;border-radius:24px 24px 0 0;padding:24px 20px;width:100%;border-top:1px solid #1c2333}.sheet-panel h3{font-size:16px;font-weight:800;margin-bottom:14px}.s-inp{width:100%;background:#07090f;border:1px solid #1c2333;border-radius:12px;padding:11px 14px;font-size:14px;color:#e2e8f8;font-family:inherit;outline:none;margin-bottom:10px}.s-inp:focus{border-color:#34d399}.emoji-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}.e-opt{font-size:22px;cursor:pointer;padding:4px;border-radius:8px;border:2px solid transparent}.e-opt.sel{border-color:#34d399;background:rgba(52,211,153,.1)}.s-btns{display:flex;gap:8px}.s-cancel{flex:1;background:#1c2333;border:none;color:#e2e8f8;border-radius:12px;padding:11px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit}.s-save{flex:2;background:#34d399;border:none;color:#07090f;border-radius:12px;padding:11px;font-size:14px;font-weight:800;cursor:pointer;font-family:inherit}</style><div class=\"top\"><div class=\"top-title\">Habits</div><div class=\"date-lbl\" id=\"dl\"></div><button class=\"add-btn\" onclick=\"openSheet()\">+ Add</button></div><div class=\"list\" id=\"list\"></div><div class=\"sheet\" id=\"sheet\" style=\"display:none\"><div class=\"sheet-panel\"><h3>New Habit</h3><input class=\"s-inp\" id=\"nameI\" placeholder=\"Habit name…\"><div class=\"emoji-row\" id=\"emojiRow\"></div><div class=\"s-btns\"><button class=\"s-cancel\" onclick=\"closeSheet()\">Cancel</button><button class=\"s-save\" onclick=\"saveH()\">Save</button></div></div></div><script>var EMOJIS=['💪','📚','🏃','🧘','💧','🥗','😴','🎸','✍️','🌿','🧹','💊','🎯','🚴','🧠'];var habits=[],selE='💪';var TODAY=new Date().toISOString().slice(0,10);function dk(ago){var d=new Date();d.setDate(d.getDate()-ago);return d.toISOString().slice(0,10);}function load(){try{habits=JSON.parse(localStorage.getItem('claudroid_habits')||'[]');}catch(e){}if(!habits.length)habits=[{name:'Exercise',e:'💪',h:{}},{name:'Read',e:'📚',h:{}},{name:'Drink water',e:'💧',h:{}}];}function save(){try{localStorage.setItem('claudroid_habits',JSON.stringify(habits));}catch(e){}}function streak(h){var s=0;for(var i=0;i<365;i++){if(h.h[dk(i)])s++;else if(i>0)break;}return s;}function render(){var d=new Date();document.getElementById('dl').textContent=d.toLocaleDateString('en',{weekday:'short',month:'short',day:'numeric'});var el=document.getElementById('list');if(!habits.length){el.innerHTML='<div style=\"text-align:center;padding:50px 20px;color:#3d4a63;font-size:13px\">No habits yet.<br>Tap + Add to start!</div>';return;}el.innerHTML=habits.map(function(h,i){var done=!!h.h[TODAY],str=streak(h);var cells=Array.from({length:30},function(_,j){var k=dk(29-j);return'<div class=\"gc'+(h.h[k]?' done':'')+(k===TODAY?' today':'')+'\"></div>';}).join('');return'<div class=\"hcard\"><div class=\"hc-top\"><div class=\"hc-emoji\">'+h.e+'</div><div class=\"hc-info\"><div class=\"hc-name\">'+h.name+'</div><div class=\"hc-streak\">'+(str?'🔥 '+str+' day streak':'No streak yet')+'</div></div><button class=\"hcheck'+(done?' done':'')+'\" onclick=\"toggle('+i+')\">'+(done?'✓':'')+'</button><button class=\"hc-del\" onclick=\"delH('+i+')\">×</button></div><div class=\"grid\">'+cells+'</div></div>';}).join('');}function toggle(i){if(habits[i].h[TODAY])delete habits[i].h[TODAY];else habits[i].h[TODAY]=1;save();render();}function delH(i){if(!confirm('Delete habit?'))return;habits.splice(i,1);save();render();}function openSheet(){selE=EMOJIS[0];document.getElementById('nameI').value='';document.getElementById('emojiRow').innerHTML=EMOJIS.map(function(e){return'<div class=\"e-opt'+(e===selE?' sel':'')+'\" onclick=\"pickE(this,''+e+'')\">' +e+'</div>';}).join('');document.getElementById('sheet').style.display='flex';}function pickE(el,e){selE=e;document.querySelectorAll('.e-opt').forEach(function(x){x.classList.remove('sel');});el.classList.add('sel');}function closeSheet(){document.getElementById('sheet').style.display='none';}function saveH(){var n=document.getElementById('nameI').value.trim();if(!n)return;if(habits.length>=10){alert('Max 10 habits');return;}habits.push({name:n,e:selE,h:{}});save();closeSheet();render();}load();render();</script>"}