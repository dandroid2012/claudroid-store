{"name":"Snake","icon":"🐍","desc":"Classic Snake game. Eat the apple, don't hit the walls!","version":"v1.0","color":"#0a1f0a","html":"<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>*{margin:0;padding:0;box-sizing:border-box}body{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:12px;overflow:hidden;user-select:none}.header{display:flex;align-items:center;gap:16px}.score-box{background:#0e1117;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:8px 18px;text-align:center}.score-num{font-size:28px;font-weight:200;font-family:monospace;color:#34d399}.score-lbl{font-size:9px;font-weight:800;color:#6b7a99;text-transform:uppercase;letter-spacing:.5px}canvas{border-radius:16px;border:1px solid rgba(255,255,255,.08);display:block}.controls{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;width:156px}.ctrl-btn{background:#0e1117;border:1px solid rgba(255,255,255,.08);border-radius:10px;color:#e2e8f8;font-size:18px;height:44px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .1s;-webkit-tap-highlight-color:transparent}.ctrl-btn:active{background:#1c2333}.ctrl-btn.wide{grid-column:span 3;font-size:13px;font-weight:700;color:#34d399;letter-spacing:.3px}.spacer{visibility:hidden}</style></head><body><div class=\"header\"><div class=\"score-box\"><div class=\"score-num\" id=\"sc\">0</div><div class=\"score-lbl\">Score</div></div><div class=\"score-box\"><div class=\"score-num\" id=\"hi\">0</div><div class=\"score-lbl\">Best</div></div></div><canvas id=\"c\"></canvas><div class=\"controls\"><div class=\"spacer\"></div><button class=\"ctrl-btn\" id=\"bU\">↑</button><div class=\"spacer\"></div><button class=\"ctrl-btn\" id=\"bL\">←</button><button class=\"ctrl-btn wide\" id=\"bS\">START</button><button class=\"ctrl-btn\" id=\"bR\">→</button><div class=\"spacer\"></div><button class=\"ctrl-btn\" id=\"bD\">↓</button><div class=\"spacer\"></div></div><script>const canvas=document.getElementById('c');const ctx=canvas.getContext('2d');const SZ=16;const COLS=20;const ROWS=20;canvas.width=COLS*SZ;canvas.height=ROWS*SZ;let snake,dir,next,food,score,hi=0,running=false,loop;function rand(n){return Math.floor(Math.random()*n)}function newFood(){let f;do{f={x:rand(COLS),y:rand(ROWS)}}while(snake.some(s=>s.x===f.x&&s.y===f.y));return f}function start(){snake=[{x:10,y:10},{x:9,y:10},{x:8,y:10}];dir={x:1,y:0};next={x:1,y:0};food=newFood();score=0;upScore();running=true;document.getElementById('bS').textContent='RESTART';clearInterval(loop);loop=setInterval(tick,130)}function tick(){dir=next;const head={x:snake[0].x+dir.x,y:snake[0].y+dir.y};if(head.x<0||head.x>=COLS||head.y<0||head.y>=ROWS||snake.some(s=>s.x===head.x&&s.y===head.y)){gameOver();return}snake.unshift(head);if(head.x===food.x&&head.y===food.y){score++;if(score>hi)hi=score;upScore();food=newFood()}else{snake.pop()}draw()}function gameOver(){clearInterval(loop);running=false;ctx.fillStyle='rgba(7,9,15,.75)';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle='#f87171';ctx.font='bold 22px system-ui';ctx.textAlign='center';ctx.fillText('GAME OVER',canvas.width/2,canvas.height/2-10);ctx.fillStyle='#6b7a99';ctx.font='13px system-ui';ctx.fillText('Score: '+score,canvas.width/2,canvas.height/2+14);document.getElementById('bS').textContent='PLAY AGAIN'}function upScore(){document.getElementById('sc').textContent=score;document.getElementById('hi').textContent=hi}function draw(){ctx.fillStyle='#07090f';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle='rgba(255,255,255,.02)';for(let x=0;x<COLS;x++)for(let y=0;y<ROWS;y++)if((x+y)%2===0)ctx.fillRect(x*SZ,y*SZ,SZ,SZ);snake.forEach((s,i)=>{const t=1-i/snake.length;ctx.fillStyle=`rgba(52,${Math.floor(180+t*31)},${Math.floor(100+t*53)},${0.7+t*0.3})`;const p=2;ctx.beginPath();ctx.roundRect(s.x*SZ+p,s.y*SZ+p,SZ-p*2,SZ-p*2,4);ctx.fill()});ctx.fillStyle='#f87171';ctx.beginPath();ctx.arc(food.x*SZ+SZ/2,food.y*SZ+SZ/2,SZ/2-2,0,Math.PI*2);ctx.fill();ctx.fillStyle='rgba(248,113,113,.2)';ctx.beginPath();ctx.arc(food.x*SZ+SZ/2,food.y*SZ+SZ/2,SZ/2+2,0,Math.PI*2);ctx.fill()}function setDir(dx,dy){if(running&&!(dx===-dir.x&&dy===-dir.y))next={x:dx,y:dy}}document.getElementById('bU').onclick=()=>setDir(0,-1);document.getElementById('bD').onclick=()=>setDir(0,1);document.getElementById('bL').onclick=()=>setDir(-1,0);document.getElementById('bR').onclick=()=>setDir(1,0);document.getElementById('bS').onclick=start;document.addEventListener('keydown',e=>{if(e.key==='ArrowUp')setDir(0,-1);else if(e.key==='ArrowDown')setDir(0,1);else if(e.key==='ArrowLeft')setDir(-1,0);else if(e.key==='ArrowRight')setDir(1,0);else if(e.key===' ')start()});ctx.fillStyle='#07090f';ctx.fillRect(0,0,canvas.width,canvas.height);ctx.fillStyle='#34d399';ctx.font='bold 18px system-ui';ctx.textAlign='center';ctx.fillText('🐍 Snake',canvas.width/2,canvas.height/2-8);ctx.fillStyle='#6b7a99';ctx.font='12px system-ui';ctx.fillText('Press START to play',canvas.width/2,canvas.height/2+14);<\/script></body></html>"}
