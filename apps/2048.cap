{"name": "2048", "icon": "🎯", "desc": "Slide tiles to combine them and reach 2048! Swipe or use arrow keys. Includes undo and best score tracking.", "version": "v1.0", "color": "#07090f", "html": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\"><style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}\nbody{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;display:flex;flex-direction:column;align-items:center;height:100vh;overflow:hidden;user-select:none;touch-action:none}\nh1{font-size:28px;font-weight:900;letter-spacing:-1px;margin-top:16px}\n.meta{display:flex;gap:12px;margin:10px 0}\n.box{background:#151b26;border-radius:12px;padding:8px 16px;text-align:center;min-width:80px}\n.box-lbl{font-size:10px;font-weight:800;color:#6b7a99;text-transform:uppercase;letter-spacing:.5px}\n.box-val{font-size:18px;font-weight:800}\n.board{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;background:#0e1117;border-radius:16px;padding:10px;width:min(90vw,340px)}\n.cell{aspect-ratio:1;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:clamp(14px,5vw,26px);transition:background .1s,transform .08s;background:#1c2333}\n.cell[data-v=\"2\"]{background:#4f8ef7;color:#fff}\n.cell[data-v=\"4\"]{background:#a78bfa;color:#fff}\n.cell[data-v=\"8\"]{background:#34d399;color:#000}\n.cell[data-v=\"16\"]{background:#fbbf24;color:#000}\n.cell[data-v=\"32\"]{background:#f97316;color:#fff}\n.cell[data-v=\"64\"]{background:#ef4444;color:#fff}\n.cell[data-v=\"128\"]{background:#ec4899;color:#fff;font-size:clamp(11px,3.5vw,20px)}\n.cell[data-v=\"256\"]{background:#8b5cf6;color:#fff;font-size:clamp(11px,3.5vw,20px)}\n.cell[data-v=\"512\"]{background:#06b6d4;color:#fff;font-size:clamp(11px,3.5vw,20px)}\n.cell[data-v=\"1024\"]{background:#10b981;color:#fff;font-size:clamp(9px,3vw,16px)}\n.cell[data-v=\"2048\"]{background:linear-gradient(135deg,#fbbf24,#f97316);color:#fff;font-size:clamp(9px,3vw,16px)}\n.cell.pop{animation:pop .12s ease}\n@keyframes pop{0%{transform:scale(1.15)}100%{transform:scale(1)}}\n.btns{display:flex;gap:10px;margin-top:12px}\nbutton{background:#151b26;border:1px solid rgba(255,255,255,.1);color:#e2e8f8;border-radius:12px;padding:10px 20px;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer}\nbutton:active{background:#1c2333}\n.msg{font-size:13px;color:#6b7a99;margin-top:8px;min-height:18px}\n</style></head><body>\n<h1>2048</h1>\n<div class=\"meta\">\n  <div class=\"box\"><div class=\"box-lbl\">Score</div><div class=\"box-val\" id=\"score\">0</div></div>\n  <div class=\"box\"><div class=\"box-lbl\">Best</div><div class=\"box-val\" id=\"best\">0</div></div>\n  <div class=\"box\"><div class=\"box-lbl\">Moves</div><div class=\"box-val\" id=\"moves\">0</div></div>\n</div>\n<div class=\"board\" id=\"board\"></div>\n<div class=\"msg\" id=\"msg\"></div>\n<div class=\"btns\"><button onclick=\"newGame()\">New Game</button><button onclick=\"undo()\">↩ Undo</button></div>\n<script>\nlet grid,score,moves,best=0,prev=null,won=false;\nfunction newGame(){grid=Array(16).fill(0);score=0;moves=0;won=false;prev=null;addTile();addTile();render();setMsg('');}\nfunction addTile(){const empty=grid.map((v,i)=>v===0?i:-1).filter(i=>i>=0);if(!empty.length)return;const i=empty[Math.floor(Math.random()*empty.length)];grid[i]=Math.random()<0.9?2:4;return i;}\nfunction render(){\n  const b=document.getElementById('board');b.innerHTML='';\n  grid.forEach(v=>{const c=document.createElement('div');c.className='cell';if(v){c.dataset.v=v;c.textContent=v;}b.appendChild(c);});\n  document.getElementById('score').textContent=score;\n  document.getElementById('best').textContent=best;\n  document.getElementById('moves').textContent=moves;\n}\nfunction setMsg(m){document.getElementById('msg').textContent=m;}\nfunction slide(row){const f=row.filter(v=>v);let r=[];for(let i=0;i<f.length;i++){if(i+1<f.length&&f[i]===f[i+1]){const merged=f[i]*2;r.push(merged);score+=merged;if(merged===2048&&!won){won=true;setMsg('🎉 You reached 2048!');}i++;}else r.push(f[i]);}while(r.length<4)r.push(0);return r;}\nfunction move(dir){\n  prev={grid:[...grid],score,moves};\n  let moved=false;\n  if(dir===0){for(let r=0;r<4;r++){const old=grid.slice(r*4,r*4+4);const nw=slide(old);nw.forEach((v,c)=>{if(grid[r*4+c]!==v)moved=true;grid[r*4+c]=v;});}}\n  else if(dir===1){for(let r=0;r<4;r++){const old=[grid[r*4],grid[r*4+1],grid[r*4+2],grid[r*4+3]].reverse();const nw=slide(old).reverse();nw.forEach((v,c)=>{if(grid[r*4+c]!==v)moved=true;grid[r*4+c]=v;});}}\n  else if(dir===2){for(let c=0;c<4;c++){const old=[grid[c],grid[4+c],grid[8+c],grid[12+c]];const nw=slide(old);nw.forEach((v,r)=>{if(grid[r*4+c]!==v)moved=true;grid[r*4+c]=v;});}}\n  else{for(let c=0;c<4;c++){const old=[grid[c],grid[4+c],grid[8+c],grid[12+c]].reverse();const nw=slide(old).reverse();nw.forEach((v,r)=>{if(grid[r*4+c]!==v)moved=true;grid[r*4+c]=v;});}}\n  if(moved){moves++;addTile();if(score>best)best=score;if(isOver()&&!won)setMsg('Game over! No moves left.');}\n  render();\n}\nfunction isOver(){if(grid.includes(0))return false;for(let r=0;r<4;r++)for(let c=0;c<4;c++){const i=r*4+c;if(c<3&&grid[i]===grid[i+1])return false;if(r<3&&grid[i]===grid[i+4])return false;}return true;}\nfunction undo(){if(!prev)return;grid=prev.grid;score=prev.score;moves=prev.moves;prev=null;render();}\n// Keyboard\ndocument.addEventListener('keydown',e=>{if(e.key==='ArrowLeft')move(0);else if(e.key==='ArrowRight')move(1);else if(e.key==='ArrowUp')move(2);else if(e.key==='ArrowDown')move(3);});\n// Swipe\nlet tx=0,ty=0;\ndocument.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});\ndocument.addEventListener('touchend',e=>{const dx=e.changedTouches[0].clientX-tx,dy=e.changedTouches[0].clientY-ty;if(Math.max(Math.abs(dx),Math.abs(dy))<20)return;if(Math.abs(dx)>Math.abs(dy))move(dx<0?0:1);else move(dy<0?2:3);});\nnewGame();\n</script></body></html>"}