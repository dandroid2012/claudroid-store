{"id": "com.claudroid.pomodoro", "name": "Pomodoro", "desc": "Focus timer with work/short break/long break cycles. Customisable durations, session counter, audio alert.", "icon": "🍅", "color": "#2e0a0a", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box}body{background:#1a0505;color:#ffe4e4;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;overflow:hidden}.mode-row{display:flex;gap:8px;margin-bottom:22px}.mode-btn{padding:7px 16px;border-radius:20px;border:1px solid #3d1515;background:#2a0a0a;color:#ffb4b4;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}.mode-btn.active{background:#c53030;color:#fff;border-color:#c53030}.ring-wrap{position:relative;width:200px;height:200px;margin-bottom:20px}.ring{width:200px;height:200px;transform:rotate(-90deg)}.ring-bg{fill:none;stroke:#2a0a0a;stroke-width:14}.ring-prog{fill:none;stroke:#ef4444;stroke-width:14;stroke-linecap:round;transition:stroke-dashoffset .5s}.time-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}.time-big{font-size:48px;font-weight:200;letter-spacing:-2px}.time-lbl{font-size:11px;color:#ffb4b4;margin-top:4px;font-weight:700;text-transform:uppercase;letter-spacing:.8px}.controls{display:flex;gap:12px;margin-bottom:16px}.ctrl{width:54px;height:54px;border-radius:27px;border:none;font-size:22px;cursor:pointer}.start-c{background:#ef4444;color:#fff}.start-c:active{background:#b91c1c}.reset-c{background:#2a0a0a;border:1.5px solid #3d1515;color:#ffb4b4}.sessions{font-size:12px;color:#ff8080;font-weight:700;text-align:center}.tomatoes{font-size:18px;letter-spacing:2px;margin-top:4px}.settings-row{display:flex;gap:8px;margin-top:14px}.set-item{background:#2a0a0a;border:1px solid #3d1515;border-radius:12px;padding:8px 12px;text-align:center}.set-item label{font-size:9px;color:#ff8080;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:3px}.set-item input{background:none;border:none;color:#ffe4e4;font-size:16px;font-weight:700;width:40px;text-align:center;font-family:inherit;outline:none}</style><div class=\"mode-row\"><button class=\"mode-btn active\" id=\"mwork\" onclick=\"setMode('work')\">Work</button><button class=\"mode-btn\" id=\"mshort\" onclick=\"setMode('short')\">Short Break</button><button class=\"mode-btn\" id=\"mlong\" onclick=\"setMode('long')\">Long Break</button></div><div class=\"ring-wrap\"><svg class=\"ring\" viewBox=\"0 0 200 200\"><circle class=\"ring-bg\" cx=\"100\" cy=\"100\" r=\"88\"/><circle class=\"ring-prog\" id=\"rp\" cx=\"100\" cy=\"100\" r=\"88\"/></svg><div class=\"time-center\"><div class=\"time-big\" id=\"td\">25:00</div><div class=\"time-lbl\" id=\"tl\">Focus</div></div></div><div class=\"controls\"><button class=\"ctrl reset-c\" onclick=\"resetTimer()\">↺</button><button class=\"ctrl start-c\" id=\"sb\" onclick=\"toggleTimer()\">▶</button></div><div class=\"sessions\"><div id=\"sc\">Session 1</div><div class=\"tomatoes\" id=\"tr\"></div></div><div class=\"settings-row\"><div class=\"set-item\"><label>Work</label><input type=\"number\" id=\"sw\" value=\"25\" min=\"1\" max=\"99\" onchange=\"updateD()\"></div><div class=\"set-item\"><label>Short</label><input type=\"number\" id=\"ss\" value=\"5\" min=\"1\" max=\"99\" onchange=\"updateD()\"></div><div class=\"set-item\"><label>Long</label><input type=\"number\" id=\"sl\" value=\"15\" min=\"1\" max=\"99\" onchange=\"updateD()\"></div></div><script>var CIRC=2*Math.PI*88,mode='work',running=false,rem=0,total=0,iv=null,sessions=0,tomatoes=0;var D={work:25*60,short:5*60,long:15*60};var COLORS={work:'#ef4444',short:'#22c55e',long:'#3b82f6'};var LABELS={work:'Focus',short:'Short Break',long:'Long Break'};function updateD(){D.work=+document.getElementById('sw').value*60;D.short=+document.getElementById('ss').value*60;D.long=+document.getElementById('sl').value*60;if(!running){rem=D[mode];total=rem;render();}}function setMode(m){if(running)return;mode=m;['work','short','long'].forEach(function(x){document.getElementById('m'+x).classList.toggle('active',x===m);});document.getElementById('rp').style.stroke=COLORS[m];document.getElementById('tl').textContent=LABELS[m];rem=D[m];total=rem;render();}function pad(n){return String(Math.floor(n)).padStart(2,'0');}function render(){document.getElementById('td').textContent=pad(rem/60)+':'+pad(rem%60);document.getElementById('rp').style.strokeDasharray=CIRC;document.getElementById('rp').style.strokeDashoffset=CIRC*(1-(total>0?rem/total:1));}function toggleTimer(){if(running){running=false;clearInterval(iv);document.getElementById('sb').textContent='▶';}else{running=true;document.getElementById('sb').textContent='⏸';iv=setInterval(tick,1000);}}function tick(){if(rem<=0){clearInterval(iv);running=false;document.getElementById('sb').textContent='▶';onComplete();return;}rem--;render();}function onComplete(){beep();if(mode==='work'){tomatoes++;sessions++;document.getElementById('tr').textContent='🍅'.repeat(Math.min(tomatoes,8));}setMode(mode==='work'?(sessions%4===0?'long':'short'):'work');document.getElementById('sc').textContent='Session '+(sessions+1);}function resetTimer(){clearInterval(iv);running=false;document.getElementById('sb').textContent='▶';rem=D[mode];total=rem;render();}function beep(){try{var c=new(window.AudioContext||window.webkitAudioContext)(),o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.frequency.value=880;g.gain.setValueAtTime(.4,c.currentTime);g.gain.exponentialRampToValueAtTime(.001,c.currentTime+.6);o.start();o.stop(c.currentTime+.6);}catch(e){}}document.getElementById('rp').style.stroke=COLORS[mode];rem=D[mode];total=rem;render();</script>"}