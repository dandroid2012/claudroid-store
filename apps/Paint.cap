{"id": "com.claudroid.paint", "name": "Paint", "desc": "Touch-based drawing app. Pen, eraser, fill bucket, adjustable size, colour picker, undo/redo, save as PNG.", "icon": "🎨", "color": "#1a0a2e", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box;user-select:none;-webkit-user-select:none}body{background:#1a0a2e;display:flex;flex-direction:column;height:100vh;font-family:system-ui,sans-serif;overflow:hidden}#toolbar{display:flex;align-items:center;gap:6px;padding:8px 10px;background:#120820;border-bottom:1px solid #2d1f4a;flex-wrap:wrap;flex-shrink:0}#canvas{flex:1;display:block;touch-action:none;cursor:crosshair;background:#fff}.tool-btn{background:#2d1f4a;border:1.5px solid #3d2f5a;color:#e0d0ff;border-radius:10px;padding:6px 10px;font-size:13px;cursor:pointer;transition:all .15s;font-family:inherit}.tool-btn.active{background:#7c3aed;border-color:#9d5cff}.swatch{width:22px;height:22px;border-radius:7px;cursor:pointer;border:2px solid transparent;transition:all .12s;flex-shrink:0;display:inline-block}.swatch.active{border-color:#fff;transform:scale(1.18)}</style><div id=\"toolbar\"><button class=\"tool-btn active\" id=\"penBtn\" onclick=\"setTool('pen')\">✏️</button><button class=\"tool-btn\" id=\"eraserBtn\" onclick=\"setTool('eraser')\">🧹</button><button class=\"tool-btn\" id=\"fillBtn\" onclick=\"setTool('fill')\">🪣</button><input type=\"range\" id=\"sizeSlider\" min=\"1\" max=\"60\" value=\"8\" style=\"width:70px;accent-color:#7c3aed\"><div id=\"colorRow\" style=\"display:flex;gap:5px;flex-wrap:wrap\"></div><input type=\"color\" id=\"colorPicker\" value=\"#222222\" style=\"width:28px;height:28px;border-radius:7px;border:2px solid #555;cursor:pointer;padding:1px\"><button class=\"tool-btn\" onclick=\"undo()\">↩</button><button class=\"tool-btn\" onclick=\"redo()\">↪</button><button class=\"tool-btn\" style=\"color:#f87171\" onclick=\"clearCanvas()\">🗑</button><button class=\"tool-btn\" style=\"color:#34d399\" onclick=\"savePNG()\">💾</button></div><canvas id=\"canvas\"></canvas><script>var canvas=document.getElementById('canvas'),ctx=canvas.getContext('2d');var tool='pen',color='#222222',size=8,drawing=false,lastX=0,lastY=0,undoStack=[],redoStack=[];var COLORS=['#222222','#ef4444','#f97316','#eab308','#22c55e','#3b82f6','#8b5cf6','#ec4899','#ffffff','#94a3b8','#78350f'];function initColors(){var row=document.getElementById('colorRow');COLORS.forEach(function(c){var s=document.createElement('div');s.className='swatch'+(c===color?' active':'');s.style.background=c;s.onclick=function(){color=c;document.querySelectorAll('.swatch').forEach(function(x){x.classList.remove('active');});s.classList.add('active');};row.appendChild(s);});}document.getElementById('colorPicker').onchange=function(){color=this.value;};document.getElementById('sizeSlider').oninput=function(){size=+this.value;};function setTool(t){tool=t;['pen','eraser','fill'].forEach(function(x){document.getElementById(x+'Btn').classList.toggle('active',x===t);});}function resize(){var r=canvas.parentElement.getBoundingClientRect();var img=ctx.getImageData(0,0,canvas.width,canvas.height);canvas.width=r.width;canvas.height=r.height;ctx.fillStyle='#fff';ctx.fillRect(0,0,canvas.width,canvas.height);try{ctx.putImageData(img,0,0);}catch(e){}}function saveState(){undoStack.push(canvas.toDataURL());if(undoStack.length>30)undoStack.shift();redoStack=[];}function restoreState(stack,other){if(!stack.length)return;other.push(canvas.toDataURL());var img=new Image();img.onload=function(){ctx.clearRect(0,0,canvas.width,canvas.height);ctx.drawImage(img,0,0);};img.src=stack.pop();}function undo(){restoreState(undoStack,redoStack);}function redo(){restoreState(redoStack,undoStack);}function clearCanvas(){saveState();ctx.fillStyle='#fff';ctx.fillRect(0,0,canvas.width,canvas.height);}function savePNG(){var a=document.createElement('a');a.download='paint.png';a.href=canvas.toDataURL();a.click();}function floodFill(x,y,fc){var id=ctx.getImageData(0,0,canvas.width,canvas.height),d=id.data;var i=(y*canvas.width+x)*4,tr=d[i],tg=d[i+1],tb=d[i+2];var fr=parseInt(fc.slice(1,3),16),fg=parseInt(fc.slice(3,5),16),fb=parseInt(fc.slice(5,7),16);if(tr===fr&&tg===fg&&tb===fb)return;var stack=[[x,y]];while(stack.length){var p=stack.pop(),px=p[0],py=p[1];if(px<0||px>=canvas.width||py<0||py>=canvas.height)continue;var j=(py*canvas.width+px)*4;if(d[j]!==tr||d[j+1]!==tg||d[j+2]!==tb)continue;d[j]=fr;d[j+1]=fg;d[j+2]=fb;d[j+3]=255;stack.push([px+1,py],[px-1,py],[px,py+1],[px,py-1]);}ctx.putImageData(id,0,0);}function getPos(e){var r=canvas.getBoundingClientRect(),src=e.touches?e.touches[0]:e;return[src.clientX-r.left,src.clientY-r.top];}canvas.addEventListener('mousedown',function(e){var p=getPos(e);if(tool==='fill'){saveState();floodFill(Math.round(p[0]),Math.round(p[1]),color);return;}saveState();drawing=true;lastX=p[0];lastY=p[1];ctx.beginPath();ctx.arc(p[0],p[1],size/2,0,Math.PI*2);ctx.fillStyle=tool==='eraser'?'#fff':color;ctx.fill();});canvas.addEventListener('mousemove',function(e){if(!drawing)return;var p=getPos(e);ctx.beginPath();ctx.strokeStyle=tool==='eraser'?'#fff':color;ctx.lineWidth=size;ctx.lineCap='round';ctx.lineJoin='round';ctx.moveTo(lastX,lastY);ctx.lineTo(p[0],p[1]);ctx.stroke();lastX=p[0];lastY=p[1];});canvas.addEventListener('mouseup',function(){drawing=false;});canvas.addEventListener('touchstart',function(e){e.preventDefault();var p=getPos(e);if(tool==='fill'){saveState();floodFill(Math.round(p[0]),Math.round(p[1]),color);return;}saveState();drawing=true;lastX=p[0];lastY=p[1];},{passive:false});canvas.addEventListener('touchmove',function(e){e.preventDefault();if(!drawing)return;var p=getPos(e);ctx.beginPath();ctx.strokeStyle=tool==='eraser'?'#fff':color;ctx.lineWidth=size;ctx.lineCap='round';ctx.lineJoin='round';ctx.moveTo(lastX,lastY);ctx.lineTo(p[0],p[1]);ctx.stroke();lastX=p[0];lastY=p[1];},{passive:false});canvas.addEventListener('touchend',function(){drawing=false;});window.addEventListener('resize',resize);resize();initColors();</script>"}