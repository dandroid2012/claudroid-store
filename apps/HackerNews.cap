{"name":"Hacker News","icon":"<svg viewBox=\"0 0 32 32\" xmlns=\"http://www.w3.org/2000/svg\"><rect width=\"32\" height=\"32\" rx=\"4\" fill=\"#FF6600\"/><text x=\"8\" y=\"22\" font-size=\"18\" font-family=\"monospace\" font-weight=\"900\" fill=\"white\">Y</text></svg>","desc":"Browse Hacker News — top stories, new, ask, show, jobs. Read full articles, comments, and discussions. Powered by the official HN API.","version":"v1.0","capVersion":"1","codename":"com.claudroid.hackernews","color":"#FF6600","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}\n:root{--bg:#f6f6ef;--s1:#fff;--s2:#f0f0e8;--s3:#e8e8e0;--orange:#ff6600;--text:#111;--t2:#666;--t3:#999;--border:#e0e0d8;--link:#0066cc;--r:10px}\nhtml,body{height:100%;overflow:hidden;background:var(--bg)}\nbody{display:flex;flex-direction:column;font-family:-apple-system,system-ui,monospace;color:var(--text)}\n\n.topbar{height:48px;background:var(--orange);display:flex;align-items:center;padding:0 12px;gap:10px;flex-shrink:0}\n.hn-logo{width:28px;height:28px;background:#fff;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:16px;color:var(--orange);border-radius:3px;flex-shrink:0}\n.topbar-title{font-size:15px;font-weight:700;color:#fff;flex:1}\n.topbar-btn{background:rgba(0,0,0,0.2);border:none;color:#fff;border-radius:6px;padding:5px 10px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}\n\n.tabs{display:flex;background:var(--s1);border-bottom:2px solid var(--border);flex-shrink:0;overflow-x:auto;scrollbar-width:none}\n.tabs::-webkit-scrollbar{display:none}\n.tab{padding:10px 14px;font-size:12px;font-weight:700;color:var(--t2);cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;margin-bottom:-2px;flex-shrink:0;font-family:monospace}\n.tab.active{color:var(--orange);border-bottom-color:var(--orange)}\n\n.feed{flex:1;overflow-y:auto;background:var(--bg)}\n.feed::-webkit-scrollbar{width:3px}\n.feed::-webkit-scrollbar-thumb{background:#ccc}\n\n.story-card{background:var(--s1);border-bottom:1px solid var(--border);padding:10px 12px;cursor:pointer;transition:background .1s;display:flex;gap:10px;align-items:flex-start}\n.story-card:active{background:var(--s2)}\n.story-rank{width:28px;font-size:12px;font-weight:700;color:var(--t3);flex-shrink:0;padding-top:1px;text-align:right}\n.story-body{flex:1;min-width:0}\n.story-title{font-size:14px;font-weight:600;line-height:1.4;color:var(--text);margin-bottom:4px;word-break:break-word}\n.story-title a{color:var(--text);text-decoration:none}\n.story-domain{font-size:11px;color:var(--t2);margin-bottom:4px}\n.story-meta{font-size:11px;color:var(--t3);display:flex;flex-wrap:wrap;gap:8px;align-items:center}\n.story-score{color:var(--orange);font-weight:700}\n.story-type{background:var(--orange);color:#fff;font-size:9px;font-weight:800;padding:2px 5px;border-radius:3px;text-transform:uppercase}\n.story-comments{cursor:pointer;color:var(--link);font-weight:600}\n\n/* POST SCREEN */\n#postScreen{position:absolute;inset:0;background:var(--bg);z-index:100;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .25s ease}\n#postScreen.open{transform:translateX(0)}\n.post-topbar{height:48px;background:var(--orange);display:flex;align-items:center;padding:0 12px;gap:8px;flex-shrink:0}\n.back-btn{background:rgba(0,0,0,0.2);border:none;color:#fff;border-radius:6px;padding:5px 8px;font-size:14px;cursor:pointer;font-family:inherit;font-weight:700}\n.post-topbar-title{font-size:13px;font-weight:700;color:#fff;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}\n.post-detail{flex:1;overflow-y:auto}\n.post-hero{background:var(--s1);padding:14px 12px;border-bottom:1px solid var(--border)}\n.post-hero-title{font-size:16px;font-weight:700;line-height:1.4;margin-bottom:6px}\n.post-hero-url{font-size:12px;color:var(--link);margin-bottom:8px;word-break:break-all}\n.post-hero-meta{font-size:12px;color:var(--t2);display:flex;gap:10px;flex-wrap:wrap}\n.post-hero-score{color:var(--orange);font-weight:700}\n.open-link-btn{display:block;background:var(--orange);color:#fff;border:none;border-radius:8px;padding:10px 14px;text-align:center;font-size:13px;font-weight:700;margin:10px 0 4px;cursor:pointer;font-family:inherit;text-decoration:none}\n.post-selftext{font-size:13px;line-height:1.7;color:var(--t2);margin-top:8px;padding-top:8px;border-top:1px solid var(--border)}\n\n.comments-header{padding:10px 12px 6px;font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.5px;color:var(--t3);background:var(--bg);border-bottom:1px solid var(--border)}\n.comment{padding:10px 12px;border-bottom:1px solid var(--border);background:var(--s1)}\n.comment.depth-1{padding-left:22px;border-left:3px solid #e0e0d8}\n.comment.depth-2{padding-left:34px;border-left:3px solid #d0d0c8}\n.comment.depth-3{padding-left:46px;border-left:3px solid #c0c0b8}\n.comment.depth-4{padding-left:58px}\n.comment-author{font-size:11px;font-weight:800;color:var(--orange);margin-bottom:5px;display:flex;align-items:center;gap:8px}\n.comment-author .time{font-weight:400;color:var(--t3)}\n.comment-body{font-size:13px;line-height:1.6;color:var(--text);word-break:break-word}\n.comment-body a{color:var(--link)}\n.comment-body p{margin-top:6px}\n.comment-body p:first-child{margin-top:0}\n.comment-body pre{background:var(--s2);padding:8px;border-radius:4px;overflow-x:auto;font-size:11px;margin-top:6px}\n.comment-body code{background:var(--s2);padding:1px 4px;border-radius:3px;font-size:12px}\n.more-replies{padding:8px 12px;font-size:11px;color:var(--link);cursor:pointer;background:var(--bg)}\n\n.loader{display:flex;align-items:center;justify-content:center;padding:40px;gap:10px;color:var(--t2);font-size:13px}\n.spinner{width:24px;height:24px;border:2px solid var(--border);border-top-color:var(--orange);border-radius:50%;animation:spin .8s linear infinite;flex-shrink:0}\n@keyframes spin{to{transform:rotate(360deg)}}\n.error-box{padding:20px;text-align:center;color:var(--t2);font-size:13px}\n.retry-btn{margin-top:10px;background:var(--orange);color:#fff;border:none;border-radius:8px;padding:8px 16px;font-size:12px;font-family:inherit;cursor:pointer;font-weight:700}\n\n#toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(20px);background:#222;color:#fff;padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600;opacity:0;transition:.3s;pointer-events:none;z-index:999;white-space:nowrap}\n#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}\n</style>\n</head>\n<body>\n<div class=\"topbar\">\n  <div class=\"hn-logo\">Y</div>\n  <div class=\"topbar-title\">Hacker News</div>\n  <button class=\"topbar-btn\" id=\"refreshBtn\" onclick=\"loadFeed()\">↺ Refresh</button>\n</div>\n<div class=\"tabs\" id=\"tabs\">\n  <div class=\"tab active\" onclick=\"switchTab('top',this)\">Top</div>\n  <div class=\"tab\" onclick=\"switchTab('new',this)\">New</div>\n  <div class=\"tab\" onclick=\"switchTab('best',this)\">Best</div>\n  <div class=\"tab\" onclick=\"switchTab('ask',this)\">Ask HN</div>\n  <div class=\"tab\" onclick=\"switchTab('show',this)\">Show HN</div>\n  <div class=\"tab\" onclick=\"switchTab('job',this)\">Jobs</div>\n</div>\n<div class=\"feed\" id=\"feed\"></div>\n\n<div id=\"postScreen\">\n  <div class=\"post-topbar\">\n    <button class=\"back-btn\" onclick=\"closePost()\">◀</button>\n    <div class=\"post-topbar-title\" id=\"postTopTitle\">Story</div>\n  </div>\n  <div class=\"post-detail\" id=\"postDetail\"></div>\n</div>\n\n<div id=\"toast\"></div>\n\n<script>\nvar curTab='top';\nvar storyCache={};\nvar storyIds=[];\nvar storyPage=0;\nvar PAGE_SIZE=20;\nvar loading=false;\n\nvar TAB_URLS={\n  top:'https://hacker-news.firebaseio.com/v0/topstories.json',\n  new:'https://hacker-news.firebaseio.com/v0/newstories.json',\n  best:'https://hacker-news.firebaseio.com/v0/beststories.json',\n  ask:'https://hacker-news.firebaseio.com/v0/askstories.json',\n  show:'https://hacker-news.firebaseio.com/v0/showstories.json',\n  job:'https://hacker-news.firebaseio.com/v0/jobstories.json'\n};\n\nasync function fetchItem(id){\n  if(storyCache[id])return storyCache[id];\n  var r=await fetch('https://hacker-news.firebaseio.com/v0/item/'+id+'.json');\n  var d=await r.json();\n  storyCache[id]=d;\n  return d;\n}\n\nasync function switchTab(tab,el){\n  curTab=tab;\n  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});\n  el.classList.add('active');\n  storyIds=[];storyPage=0;\n  document.getElementById('feed').innerHTML='';\n  loadFeed();\n}\n\nasync function loadFeed(){\n  if(loading)return;\n  loading=true;\n  var feed=document.getElementById('feed');\n  if(storyPage===0)feed.innerHTML='<div class=\"loader\"><div class=\"spinner\"></div> Loading…</div>';\n  try{\n    if(storyPage===0){\n      var r=await fetch(TAB_URLS[curTab]);\n      storyIds=await r.json();\n    }\n    var slice=storyIds.slice(storyPage*PAGE_SIZE,(storyPage+1)*PAGE_SIZE);\n    if(!slice.length){loading=false;return;}\n    if(storyPage===0)feed.innerHTML='';\n    var stories=await Promise.all(slice.map(fetchItem));\n    stories.forEach(function(s,i){\n      if(s)feed.appendChild(buildCard(s,storyPage*PAGE_SIZE+i+1));\n    });\n    storyPage++;\n    // Load more button\n    var old=document.getElementById('loadMoreBtn');\n    if(old)old.remove();\n    if(storyPage*PAGE_SIZE<storyIds.length){\n      var btn=document.createElement('div');\n      btn.id='loadMoreBtn';\n      btn.style.cssText='text-align:center;padding:14px;cursor:pointer;color:var(--orange);font-size:13px;font-weight:700;font-family:monospace;background:var(--s1);border-top:1px solid var(--border)';\n      btn.textContent='Load more stories…';\n      btn.onclick=function(){loadFeed();};\n      feed.appendChild(btn);\n    }\n  }catch(e){\n    if(storyPage===0)feed.innerHTML='<div class=\"error-box\">⚠️ Failed to load<br><button class=\"retry-btn\" onclick=\"loadFeed()\">↺ Retry</button></div>';\n  }\n  loading=false;\n}\n\nfunction buildCard(s,rank){\n  var el=document.createElement('div');\n  el.className='story-card';\n  el.onclick=function(){openPost(s);};\n  var domain='';\n  if(s.url){try{domain=new URL(s.url).hostname.replace(/^www\\./,'');}catch(e){}}\n  var type=s.type==='job'?'job':s.title&&s.title.startsWith('Ask HN:')?'ask':s.title&&s.title.startsWith('Show HN:')?'show':'';\n  var timeAgo=fmtAge(s.time);\n  el.innerHTML='<div class=\"story-rank\">'+rank+'</div>'\n    +'<div class=\"story-body\">'\n      +(type?'<span class=\"story-type\">'+type+'</span> ':'')\n      +'<div class=\"story-title\">'+esc(s.title)+'</div>'\n      +(domain?'<div class=\"story-domain\">'+esc(domain)+'</div>':'')\n      +'<div class=\"story-meta\">'\n        +'<span class=\"story-score\">▲ '+(s.score||0)+'</span>'\n        +'<span>by '+esc(s.by||'?')+'</span>'\n        +'<span>'+timeAgo+'</span>'\n        +(s.descendants!=null?'<span class=\"story-comments\">'+s.descendants+' comments</span>':'')\n      +'</div>'\n    +'</div>';\n  return el;\n}\n\nvar curStory=null;\nfunction openPost(s){\n  curStory=s;\n  document.getElementById('postTopTitle').textContent=s.title||'Story';\n  var detail=document.getElementById('postDetail');\n  var domain='';\n  if(s.url){try{domain=new URL(s.url).hostname.replace(/^www\\./,'');}catch(e){}}\n  detail.innerHTML='<div class=\"post-hero\">'\n    +'<div class=\"post-hero-title\">'+esc(s.title)+'</div>'\n    +(s.url?'<div class=\"post-hero-url\">'+esc(domain)+'</div>':'')\n    +'<div class=\"post-hero-meta\">'\n      +'<span class=\"post-hero-score\">▲ '+(s.score||0)+' points</span>'\n      +'<span>'+esc(s.by||'?')+'</span>'\n      +'<span>'+fmtAge(s.time)+'</span>'\n      +(s.descendants!=null?'<span>'+s.descendants+' comments</span>':'')\n    +'</div>'\n    +(s.url?'<a class=\"open-link-btn\" href=\"'+esc(s.url)+'\" target=\"_blank\">🔗 Open Article</a>':'')\n    +(s.text?'<div class=\"post-selftext\">'+formatHNText(s.text)+'</div>':'')\n  +'</div>'\n  +(s.kids&&s.kids.length?'<div class=\"comments-header\">'+s.descendants+' Comments</div><div id=\"commentsList\"><div class=\"loader\"><div class=\"spinner\"></div></div></div>':'<div style=\"padding:20px;text-align:center;color:var(--t3);font-size:13px\">No comments yet</div>');\n  document.getElementById('postScreen').classList.add('open');\n  if(s.kids&&s.kids.length)loadComments(s.kids);\n}\nfunction closePost(){\n  document.getElementById('postScreen').classList.remove('open');\n  curStory=null;\n}\n\nasync function loadComments(ids){\n  var list=document.getElementById('commentsList');\n  if(!list)return;\n  try{\n    var items=await Promise.all(ids.slice(0,30).map(fetchItem));\n    list.innerHTML='';\n    items.forEach(function(c){if(c&&!c.deleted&&c.text)renderComment(c,list,0);});\n    if(!list.children.length)list.innerHTML='<div style=\"padding:16px;text-align:center;color:var(--t3);font-size:13px\">No visible comments</div>';\n  }catch(e){\n    list.innerHTML='<div class=\"error-box\">Couldn\\'t load comments</div>';\n  }\n}\n\nfunction renderComment(c,parent,depth){\n  if(!c||c.deleted||c.dead)return;\n  var el=document.createElement('div');\n  el.className='comment'+(depth>0?' depth-'+Math.min(depth,4):'');\n  if(depth>0)el.style.paddingLeft=(12+depth*12)+'px';\n  el.innerHTML='<div class=\"comment-author\">'+esc(c.by||'?')+'<span class=\"time\">'+fmtAge(c.time)+'</span></div>'\n    +'<div class=\"comment-body\">'+formatHNText(c.text||'')+'</div>';\n  parent.appendChild(el);\n  if(c.kids&&c.kids.length&&depth<4){\n    c.kids.slice(0,10).forEach(function(kid){\n      fetchItem(kid).then(function(child){\n        if(child&&!child.deleted&&child.text)renderComment(child,parent,depth+1);\n      }).catch(function(){});\n    });\n    if(c.kids.length>10){\n      var more=document.createElement('div');\n      more.className='more-replies';\n      more.style.paddingLeft=(12+depth*12+12)+'px';\n      more.textContent='▶ '+(c.kids.length-10)+' more replies';\n      parent.appendChild(more);\n    }\n  }\n}\n\nfunction formatHNText(html){\n  if(!html)return '';\n  html=html.replace(/<p>/gi,'<br><br>').replace(/<\\/p>/gi,'');\n  html=html.replace(/<i>/gi,'<em>').replace(/<\\/i>/gi,'</em>');\n  html=html.replace(/<pre>/gi,'<pre>').replace(/<\\/pre>/gi,'</pre>');\n  html=html.replace(/<code>/gi,'<code>').replace(/<\\/code>/gi,'</code>');\n  html=html.replace(/<a href=\"([^\"]+)\"[^>]*>([^<]+)<\\/a>/gi,'<a href=\"$1\" target=\"_blank\">$2</a>');\n  return html;\n}\n\nfunction fmtAge(utc){\n  var d=Math.floor(Date.now()/1000-utc);\n  if(d<60)return d+'s ago';\n  if(d<3600)return Math.floor(d/60)+'m ago';\n  if(d<86400)return Math.floor(d/3600)+'h ago';\n  if(d<2592000)return Math.floor(d/86400)+'d ago';\n  return Math.floor(d/2592000)+'mo ago';\n}\nfunction esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}\nfunction toast(msg){\n  var t=document.getElementById('toast');\n  t.textContent=msg;t.classList.add('show');\n  clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},2200);\n}\nloadFeed();\n</script>\n</body>\n</html>"}
