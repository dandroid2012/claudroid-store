{"id": "com.claudroid.flashcards", "name": "Flashcards", "desc": "Study tool with flip cards and multiple decks. Spaced-repetition scoring. Create your own cards. Saved locally.", "icon": "🃏", "color": "#1a1a0a", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box;-webkit-user-select:none;user-select:none}body{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}.top{background:#0e1117;border-bottom:1px solid #1c2333;padding:11px 14px;display:flex;align-items:center;gap:10px;flex-shrink:0}.top-title{font-size:16px;font-weight:800;flex:1}.icon-btn{background:#1c2333;border:none;color:#e2e8f8;border-radius:10px;padding:7px 12px;font-size:13px;cursor:pointer;font-family:inherit}#study{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;gap:14px}#edit{flex:1;display:none;flex-direction:column;overflow:hidden}.prog{font-size:12px;color:#6b7a99;font-weight:700}.deck-row{display:flex;gap:7px;flex-wrap:wrap}.deck-chip{padding:6px 13px;border-radius:20px;border:1px solid #1c2333;background:#0e1117;color:#6b7a99;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}.deck-chip.active{background:rgba(251,191,36,.15);color:#fbbf24;border-color:rgba(251,191,36,.3)}.card-wrap{width:100%;max-width:340px;height:190px;perspective:1000px;cursor:pointer}.card{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .5s}.card.flipped{transform:rotateY(180deg)}.face{position:absolute;inset:0;border-radius:20px;display:flex;align-items:center;justify-content:center;padding:22px;text-align:center;backface-visibility:hidden;-webkit-backface-visibility:hidden}.front{background:#0e1117;border:1.5px solid #2d3748;font-size:19px;font-weight:700;line-height:1.4}.back{background:#1a2e1a;border:1.5px solid rgba(52,211,153,.3);transform:rotateY(180deg);font-size:14px;color:#a0e0b0;line-height:1.5}.hint{font-size:11px;color:#3d4a63;font-weight:600}.btn-row{display:flex;gap:10px;width:100%;max-width:340px}.r-btn{flex:1;padding:11px;border-radius:13px;border:none;font-size:13px;font-weight:800;cursor:pointer;font-family:inherit;transition:transform .1s}.r-btn:active{transform:scale(.95)}.hard{background:rgba(248,113,113,.15);color:#f87171;border:1px solid rgba(248,113,113,.3)}.ok{background:rgba(251,191,36,.12);color:#fbbf24;border:1px solid rgba(251,191,36,.3)}.easy{background:rgba(52,211,153,.12);color:#34d399;border:1px solid rgba(52,211,153,.3)}.card-list{flex:1;overflow-y:auto;padding:12px 14px}.card-item{background:#0e1117;border:1px solid #1c2333;border-radius:13px;padding:11px 13px;margin-bottom:8px;display:flex;gap:10px}.ci-main{flex:1;min-width:0}.ci-q{font-size:13px;font-weight:700;margin-bottom:3px}.ci-a{font-size:12px;color:#6b7a99}.ci-del{background:none;border:none;color:#3d4a63;font-size:16px;cursor:pointer;flex-shrink:0}.add-row{padding:11px 14px;border-top:1px solid #1c2333;display:flex;flex-direction:column;gap:7px;flex-shrink:0}.a-inp{background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:9px 12px;font-size:13px;color:#e2e8f8;font-family:inherit;outline:none;width:100%}.a-inp:focus{border-color:#fbbf24}.a-btns{display:flex;gap:8px}.a-sel{background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:9px;font-size:12px;color:#e2e8f8;font-family:inherit;outline:none;flex:1}.a-save{background:#fbbf24;border:none;color:#07090f;border-radius:10px;padding:9px 16px;font-size:13px;font-weight:800;cursor:pointer;font-family:inherit}</style><div class=\"top\"><div class=\"top-title\" id=\"topT\">Flashcards</div><button class=\"icon-btn\" id=\"editBtn\" onclick=\"toggleEdit()\">✏️ Edit</button></div><div id=\"study\"><div class=\"deck-row\" id=\"deckRow\"></div><div class=\"prog\" id=\"prog\"></div><div class=\"card-wrap\" onclick=\"flipCard()\"><div class=\"card\" id=\"card\"><div class=\"face front\" id=\"cf\"></div><div class=\"face back\" id=\"cb\"></div></div></div><div class=\"hint\" id=\"hint\">Tap to flip</div><div class=\"btn-row\" id=\"rateRow\" style=\"display:none\"><button class=\"r-btn hard\" onclick=\"rate('hard')\">😓 Hard</button><button class=\"r-btn ok\" onclick=\"rate('ok')\">🙂 OK</button><button class=\"r-btn easy\" onclick=\"rate('easy')\">😄 Easy</button></div></div><div id=\"edit\"><div style=\"padding:10px 14px\"><div class=\"deck-row\" id=\"deckRowE\"></div></div><div class=\"card-list\" id=\"cardList\"></div><div class=\"add-row\"><input class=\"a-inp\" id=\"qI\" placeholder=\"Question…\"><input class=\"a-inp\" id=\"aI\" placeholder=\"Answer…\"><div class=\"a-btns\"><select class=\"a-sel\" id=\"dSel\"></select><button class=\"a-save\" onclick=\"addCard()\">Add Card</button></div></div></div><script>var DECKS=['General','Science','History','Language','Math'];var cards=[],deck='General',queue=[],qIdx=0,flipped=false;try{cards=JSON.parse(localStorage.getItem('claudroid_cards')||'[]');}catch(e){}if(!cards.length){cards=[{q:'Speed of light?',a:'299,792,458 m/s',deck:'Science',s:0},{q:'Who wrote Romeo and Juliet?',a:'William Shakespeare',deck:'History',s:0},{q:'7 × 8 = ?',a:'56',deck:'Math',s:0}];}function save(){try{localStorage.setItem('claudroid_cards',JSON.stringify(cards));}catch(e){}}function chips(id,active,fn){document.getElementById(id).innerHTML=DECKS.map(function(d){var c=cards.filter(function(x){return x.deck===d;}).length;return'<div class=\"deck-chip'+(d===active?' active':'')+'\" onclick=\"'+fn+'(''+d+'')\">' +d+(c?' · '+c:'')+' </div>';}).join('');}function startStudy(){queue=cards.filter(function(c){return c.deck===deck;}).sort(function(a,b){return(a.s||0)-(b.s||0);});qIdx=0;showCard();}function showCard(){flipped=false;document.getElementById('card').classList.remove('flipped');document.getElementById('rateRow').style.display='none';document.getElementById('hint').textContent='Tap to flip';if(!queue.length){document.getElementById('cf').textContent='No cards in this deck.';document.getElementById('cb').textContent='Add some in Edit mode!';document.getElementById('prog').textContent='';return;}var c=queue[qIdx%queue.length];document.getElementById('cf').textContent=c.q;document.getElementById('cb').textContent=c.a;document.getElementById('prog').textContent=(qIdx%queue.length+1)+' / '+queue.length;}function flipCard(){if(flipped)return;flipped=true;document.getElementById('card').classList.add('flipped');document.getElementById('rateRow').style.display='flex';document.getElementById('hint').textContent='';}function rate(r){var c=queue[qIdx%queue.length];var idx=cards.findIndex(function(x){return x.q===c.q&&x.deck===c.deck;});if(idx>=0)cards[idx].s=(cards[idx].s||0)+(r==='easy'?2:r==='ok'?1:0);save();qIdx++;showCard();}function setDeck(d){deck=d;chips('deckRow',d,'setDeck');startStudy();}function setDeckE(d){deck=d;chips('deckRowE',d,'setDeckE');renderList();}function addCard(){var q=document.getElementById('qI').value.trim(),a=document.getElementById('aI').value.trim(),d=document.getElementById('dSel').value;if(!q||!a)return;cards.push({q:q,a:a,deck:d,s:0});save();document.getElementById('qI').value='';document.getElementById('aI').value='';renderList();chips('deckRow',deck,'setDeck');chips('deckRowE',deck,'setDeckE');}function delCard(i){if(!confirm('Delete?'))return;cards.splice(i,1);save();renderList();}function renderList(){var mine=cards.map(function(c,i){return{c:c,i:i};}).filter(function(x){return x.c.deck===deck;});document.getElementById('cardList').innerHTML=mine.map(function(x){return'<div class=\"card-item\"><div class=\"ci-main\"><div class=\"ci-q\">'+x.c.q+'</div><div class=\"ci-a\">'+x.c.a+'</div></div><button class=\"ci-del\" onclick=\"delCard('+x.i+')\">×</button></div>';}).join('')||'<div style=\"text-align:center;padding:30px;color:#3d4a63;font-size:13px\">No cards in this deck.</div>';}function toggleEdit(){var sv=document.getElementById('study'),ev=document.getElementById('edit'),btn=document.getElementById('editBtn');if(ev.style.display==='none'||!ev.style.display){ev.style.display='flex';ev.style.flexDirection='column';sv.style.display='none';btn.textContent='📖 Study';document.getElementById('topT').textContent='Edit Cards';var s=document.getElementById('dSel');s.innerHTML=DECKS.map(function(d){return'<option>'+d+'</option>';}).join('');chips('deckRowE',deck,'setDeckE');renderList();}else{ev.style.display='none';sv.style.display='flex';btn.textContent='✏️ Edit';document.getElementById('topT').textContent='Flashcards';startStudy();}}chips('deckRow',deck,'setDeck');startStudy();</script>"}