{"name":"Weather","icon":"<svg viewBox=\"0 0 32 32\" xmlns=\"http://www.w3.org/2000/svg\"><defs><linearGradient id=\"sky\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0%\" stop-color=\"#48b4f0\"/><stop offset=\"100%\" stop-color=\"#1a73e8\"/></linearGradient></defs><circle cx=\"16\" cy=\"16\" r=\"16\" fill=\"url(#sky)\"/><circle cx=\"13\" cy=\"14\" r=\"5\" fill=\"#fff\" opacity=\"0.95\"/><ellipse cx=\"18\" cy=\"16\" rx=\"7\" ry=\"5\" fill=\"#fff\"/><ellipse cx=\"10\" cy=\"16\" rx=\"5\" ry=\"4\" fill=\"#fff\" opacity=\"0.8\"/></svg>","desc":"Beautiful weather app using Open-Meteo. Get current conditions, hourly forecasts, and 7-day outlook for any city worldwide. No API key needed.","version":"v1.0","capVersion":"1","codename":"com.claudroid.weather","color":"#1a73e8","html":"<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}\n:root{--bg:#0a0f1e;--s1:#111827;--s2:#1e2a3a;--s3:#263040;--blue:#3b9eff;--cyan:#00d4ff;--text:#e8f4ff;--t2:#8ba8c8;--t3:#4a6380;--border:rgba(59,158,255,0.12);--r:16px}\nhtml,body{height:100%;overflow:hidden;background:var(--bg)}\nbody{display:flex;flex-direction:column;font-family:-apple-system,system-ui,sans-serif;color:var(--text)}\n\n/* TOP BAR */\n.topbar{height:54px;background:rgba(10,15,30,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0}\n.topbar-title{font-size:16px;font-weight:800;letter-spacing:-0.3px;flex:1}\n.topbar-title span{color:var(--blue)}\n.search-btn{width:36px;height:36px;border-radius:10px;background:var(--s2);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--t2)}\n.search-btn svg{width:18px;height:18px}\n\n/* SEARCH */\n.search-bar{display:none;align-items:center;gap:8px;padding:8px 12px;background:var(--s1);border-bottom:1px solid var(--border);flex-shrink:0}\n.search-bar.open{display:flex}\n.search-input{flex:1;background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:9px 14px;color:var(--text);font-size:14px;font-family:inherit;outline:none}\n.search-input:focus{border-color:var(--blue)}\n.search-cancel{background:transparent;border:none;color:var(--t2);font-size:13px;cursor:pointer;padding:4px 8px;font-family:inherit;font-weight:700}\n\n/* MAIN SCROLL */\n.main{flex:1;overflow-y:auto;padding:16px 14px;background:var(--bg)}\n.main::-webkit-scrollbar{width:3px}\n.main::-webkit-scrollbar-thumb{background:#1e3a5f;border-radius:2px}\n\n/* HERO CARD */\n.hero-card{background:linear-gradient(135deg,#0d2a4a 0%,#0a1a2e 60%,#0d2040 100%);border:1px solid rgba(59,158,255,0.2);border-radius:20px;padding:24px;margin-bottom:14px;position:relative;overflow:hidden}\n.hero-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(0,212,255,0.08) 0%,transparent 70%);pointer-events:none}\n.hero-location{font-size:13px;color:var(--t2);font-weight:600;margin-bottom:4px;display:flex;align-items:center;gap:5px}\n.hero-city{font-size:26px;font-weight:800;letter-spacing:-0.5px;margin-bottom:16px}\n.hero-main{display:flex;align-items:center;gap:16px;margin-bottom:16px}\n.hero-icon{font-size:72px;line-height:1;filter:drop-shadow(0 4px 12px rgba(0,0,0,0.4))}\n.hero-temp-wrap{}\n.hero-temp{font-size:64px;font-weight:300;letter-spacing:-3px;line-height:1}\n.hero-unit{font-size:28px;font-weight:300;color:var(--t2);vertical-align:super;font-size:22px}\n.hero-feels{font-size:12px;color:var(--t2);margin-top:2px}\n.hero-desc{font-size:15px;font-weight:600;color:var(--cyan);margin-bottom:14px;text-transform:capitalize}\n.hero-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}\n.hero-stat{text-align:center}\n.hero-stat-val{font-size:16px;font-weight:700}\n.hero-stat-label{font-size:10px;color:var(--t2);margin-top:2px;text-transform:uppercase;letter-spacing:0.5px}\n\n/* SECTION */\n.section-card{background:var(--s1);border:1px solid var(--border);border-radius:16px;padding:14px;margin-bottom:14px}\n.section-title{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--t2);margin-bottom:12px;display:flex;align-items:center;gap:6px}\n\n/* HOURLY */\n.hourly-scroll{display:flex;gap:8px;overflow-x:auto;scrollbar-width:none;margin:0 -14px;padding:0 14px}\n.hourly-scroll::-webkit-scrollbar{display:none}\n.hour-card{flex-shrink:0;background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:10px 12px;text-align:center;min-width:64px}\n.hour-card.now{background:linear-gradient(135deg,#0d3060,#0a1f40);border-color:rgba(59,158,255,0.4)}\n.hour-time{font-size:10px;color:var(--t2);font-weight:700;margin-bottom:6px}\n.hour-icon{font-size:22px;margin-bottom:6px}\n.hour-temp{font-size:14px;font-weight:700}\n.hour-precip{font-size:9px;color:var(--cyan);margin-top:3px}\n\n/* 7-DAY */\n.day-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--border)}\n.day-row:last-child{border-bottom:none;padding-bottom:0}\n.day-name{font-size:13px;font-weight:700;width:42px;flex-shrink:0}\n.day-icon{font-size:22px;flex-shrink:0;width:30px;text-align:center}\n.day-desc{font-size:11px;color:var(--t2);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}\n.day-precip{font-size:10px;color:var(--cyan);width:28px;text-align:right;flex-shrink:0}\n.day-bar-wrap{width:80px;flex-shrink:0;display:flex;align-items:center;gap:4px}\n.day-low{font-size:11px;color:var(--t2);width:22px;text-align:right;flex-shrink:0}\n.day-bar{flex:1;height:4px;background:#1e2a3a;border-radius:2px;position:relative;overflow:hidden}\n.day-bar-fill{position:absolute;top:0;height:100%;border-radius:2px;background:linear-gradient(90deg,#3b9eff,#00d4ff)}\n.day-high{font-size:11px;font-weight:700;width:22px;flex-shrink:0}\n\n/* UV + EXTRAS */\n.extras-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}\n.extra-card{background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:12px}\n.extra-label{font-size:10px;color:var(--t2);font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;display:flex;align-items:center;gap:5px}\n.extra-val{font-size:22px;font-weight:800}\n.extra-sub{font-size:11px;color:var(--t2);margin-top:2px}\n\n/* UV BAR */\n.uv-bar{width:100%;height:6px;border-radius:3px;background:linear-gradient(90deg,#4caf50,#ffeb3b,#ff9800,#f44336,#9c27b0);margin-top:6px;position:relative}\n.uv-dot{position:absolute;top:-2px;width:10px;height:10px;border-radius:50%;background:#fff;border:2px solid var(--bg);transform:translateX(-50%)}\n\n/* LOADER */\n.loader{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:60px 20px;gap:14px;color:var(--t2)}\n.spinner{width:36px;height:36px;border:2px solid var(--s2);border-top-color:var(--blue);border-radius:50%;animation:spin .8s linear infinite}\n@keyframes spin{to{transform:rotate(360deg)}}\n\n/* ERROR */\n.error-box{background:rgba(248,81,73,0.08);border:1px solid rgba(248,81,73,0.2);border-radius:12px;padding:16px;text-align:center;color:#f85149;font-size:13px}\n.retry-btn{margin-top:10px;background:var(--s2);border:1px solid var(--border);color:var(--text);border-radius:10px;padding:8px 18px;font-size:12px;font-family:inherit;cursor:pointer}\n\n/* TOAST */\n#toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--s2);color:var(--text);padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600;opacity:0;transition:.3s;pointer-events:none;z-index:999;white-space:nowrap;border:1px solid var(--border)}\n#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}\n</style>\n</head>\n<body>\n<div class=\"topbar\" id=\"mainBar\">\n  <div class=\"topbar-title\">☁️ <span>Weather</span></div>\n  <button class=\"search-btn\" onclick=\"openSearch()\">\n    <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg>\n  </button>\n</div>\n\n<div class=\"search-bar\" id=\"searchBar\">\n  <input class=\"search-input\" id=\"searchInput\" type=\"text\" placeholder=\"Search city…\" autocomplete=\"off\"\n    onkeydown=\"if(event.key==='Enter')doSearch()\">\n  <button class=\"search-cancel\" onclick=\"closeSearch()\">Cancel</button>\n</div>\n\n<div class=\"main\" id=\"mainContent\">\n  <div class=\"loader\" id=\"initLoader\">\n    <div class=\"spinner\"></div>\n    <div>Detecting location…</div>\n  </div>\n</div>\n\n<div id=\"toast\"></div>\n\n<script>\nvar WMO_CODES = {\n  0:'Clear Sky',1:'Mainly Clear',2:'Partly Cloudy',3:'Overcast',\n  45:'Fog',48:'Icy Fog',\n  51:'Light Drizzle',53:'Drizzle',55:'Heavy Drizzle',\n  61:'Light Rain',63:'Rain',65:'Heavy Rain',\n  71:'Light Snow',73:'Snow',75:'Heavy Snow',77:'Snow Grains',\n  80:'Showers',81:'Rain Showers',82:'Heavy Showers',\n  85:'Snow Showers',86:'Heavy Snow Showers',\n  95:'Thunderstorm',96:'Thunderstorm w/ Hail',99:'Thunderstorm w/ Heavy Hail'\n};\nvar WMO_ICON = {\n  0:'☀️',1:'🌤️',2:'⛅',3:'☁️',\n  45:'🌫️',48:'🌫️',\n  51:'🌦️',53:'🌦️',55:'🌧️',\n  61:'🌦️',63:'🌧️',65:'🌧️',\n  71:'🌨️',73:'❄️',75:'❄️',77:'🌨️',\n  80:'🌦️',81:'🌧️',82:'⛈️',\n  85:'🌨️',86:'❄️',\n  95:'⛈️',96:'⛈️',99:'⛈️'\n};\nvar WMO_NIGHT = {\n  0:'🌙',1:'🌙',2:'🌙'\n};\n\nfunction wmoDesc(c){return WMO_CODES[c]||'Unknown';}\nfunction wmoIcon(c,isNight){if(isNight&&WMO_NIGHT[c])return WMO_NIGHT[c];return WMO_ICON[c]||'🌡️';}\n\nfunction isNightHour(h){return h<6||h>=20;}\n\nvar curLat,curLon,curCity='My Location';\n\nasync function geocode(city){\n  var r=await fetch('https://geocoding-api.open-meteo.com/v1/search?name='+encodeURIComponent(city)+'&count=1&language=en&format=json');\n  var d=await r.json();\n  if(!d.results||!d.results.length)throw new Error('City not found: '+city);\n  return d.results[0];\n}\n\nasync function fetchWeather(lat,lon){\n  var url='https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+\n    '&current=temperature_2m,relative_humidity_2m,apparent_temperature,precipitation,weather_code,wind_speed_10m,wind_direction_10m,uv_index,surface_pressure,visibility'+\n    '&hourly=temperature_2m,precipitation_probability,weather_code&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,uv_index_max,sunrise,sunset'+\n    '&wind_speed_unit=kmh&timezone=auto&forecast_days=7';\n  var r=await fetch(url);\n  if(!r.ok)throw new Error('Weather API error');\n  return r.json();\n}\n\nasync function init(){\n  if(navigator.geolocation){\n    navigator.geolocation.getCurrentPosition(async function(pos){\n      curLat=pos.coords.latitude;curLon=pos.coords.longitude;\n      try{\n        var rr=await fetch('https://geocoding-api.open-meteo.com/v1/search?name=&latitude='+curLat+'&longitude='+curLon+'&count=1');\n      }catch(e){}\n      try{await loadWeather(curLat,curLon,curCity);}catch(e){showError(e.message);}\n    },async function(){\n      try{var g=await geocode('London');curLat=g.latitude;curLon=g.longitude;curCity=g.name+', '+g.country;await loadWeather(curLat,curLon,curCity);}catch(e){showError(e.message);}\n    },{timeout:5000});\n  } else {\n    try{var g=await geocode('London');curLat=g.latitude;curLon=g.longitude;curCity=g.name+', '+g.country;await loadWeather(curLat,curLon,curCity);}catch(e){showError(e.message);}\n  }\n}\n\nasync function loadWeather(lat,lon,city){\n  document.getElementById('mainContent').innerHTML='<div class=\"loader\"><div class=\"spinner\"></div><div>Loading weather…</div></div>';\n  var data=await fetchWeather(lat,lon);\n  renderWeather(data,city);\n}\n\nfunction renderWeather(data,city){\n  var c=data.current;\n  var daily=data.daily;\n  var hourly=data.hourly;\n  var now=new Date();\n  var curHour=now.getHours();\n  var nightNow=isNightHour(curHour);\n\n  // Find current hour index\n  var hi=0;\n  if(hourly&&hourly.time){\n    for(var i=0;i<hourly.time.length;i++){\n      if(new Date(hourly.time[i]).getHours()===curHour&&new Date(hourly.time[i]).getDate()===now.getDate()){hi=i;break;}\n    }\n  }\n\n  var code=c.weather_code||0;\n  var icon=wmoIcon(code,nightNow);\n  var desc=wmoDesc(code);\n  var temp=Math.round(c.temperature_2m);\n  var feels=Math.round(c.apparent_temperature);\n  var humid=c.relative_humidity_2m;\n  var wind=Math.round(c.wind_speed_10m);\n  var uv=c.uv_index||0;\n  var pressure=Math.round(c.surface_pressure||1013);\n  var vis=c.visibility?Math.round(c.visibility/1000):null;\n\n  // Days\n  var days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];\n  var dMin=Infinity,dMax=-Infinity;\n  if(daily&&daily.temperature_2m_min){daily.temperature_2m_min.forEach(function(v){if(v<dMin)dMin=v;});daily.temperature_2m_max.forEach(function(v){if(v>dMax)dMax=v;});}\n\n  var heroHTML='<div class=\"hero-card\">'\n    +'<div class=\"hero-location\">📍 '+esc(city)+'</div>'\n    +'<div class=\"hero-city\">'+esc(city.split(',')[0])+'</div>'\n    +'<div class=\"hero-main\">'\n      +'<div class=\"hero-icon\">'+icon+'</div>'\n      +'<div class=\"hero-temp-wrap\">'\n        +'<div class=\"hero-temp\">'+temp+'<span class=\"hero-unit\">°C</span></div>'\n        +'<div class=\"hero-feels\">Feels like '+feels+'°C</div>'\n      +'</div>'\n    +'</div>'\n    +'<div class=\"hero-desc\">'+esc(desc)+'</div>'\n    +'<div class=\"hero-grid\">'\n      +'<div class=\"hero-stat\"><div class=\"hero-stat-val\">'+humid+'%</div><div class=\"hero-stat-label\">Humidity</div></div>'\n      +'<div class=\"hero-stat\"><div class=\"hero-stat-val\">'+wind+'</div><div class=\"hero-stat-label\">km/h Wind</div></div>'\n      +'<div class=\"hero-stat\"><div class=\"hero-stat-val\">'+pressure+'</div><div class=\"hero-stat-label\">hPa</div></div>'\n    +'</div>'\n  +'</div>';\n\n  // Hourly (next 24h)\n  var hourlyHTML='<div class=\"section-card\">'\n    +'<div class=\"section-title\">🕐 Hourly Forecast</div>'\n    +'<div class=\"hourly-scroll\">';\n  var count=0;\n  for(var i=hi;i<Math.min(hi+24,hourly.time.length);i++){\n    var hDate=new Date(hourly.time[i]);\n    var hHour=hDate.getHours();\n    var hIsNow=(i===hi);\n    var hIcon=wmoIcon(hourly.weather_code[i],isNightHour(hHour));\n    var hTemp=Math.round(hourly.temperature_2m[i]);\n    var hPrecip=hourly.precipitation_probability[i];\n    hourlyHTML+='<div class=\"hour-card'+(hIsNow?' now':'')+'\">'\n      +'<div class=\"hour-time\">'+(hIsNow?'Now':(hHour===0?'12am':hHour<12?hHour+'am':hHour===12?'12pm':(hHour-12)+'pm'))+'</div>'\n      +'<div class=\"hour-icon\">'+hIcon+'</div>'\n      +'<div class=\"hour-temp\">'+hTemp+'°</div>'\n      +(hPrecip>0?'<div class=\"hour-precip\">💧'+hPrecip+'%</div>':'<div class=\"hour-precip\" style=\"opacity:0\">0</div>')\n    +'</div>';\n    count++;\n  }\n  hourlyHTML+='</div></div>';\n\n  // 7-day\n  var dailyHTML='<div class=\"section-card\"><div class=\"section-title\">📅 7-Day Forecast</div>';\n  if(daily&&daily.time){\n    daily.time.forEach(function(dt,idx){\n      var d=new Date(dt+'T12:00:00');\n      var dName=idx===0?'Today':idx===1?'Tmrw':days[d.getDay()];\n      var dCode=daily.weather_code[idx]||0;\n      var dIcon=wmoIcon(dCode,false);\n      var dDesc=wmoDesc(dCode);\n      var dLow=Math.round(daily.temperature_2m_min[idx]);\n      var dHigh=Math.round(daily.temperature_2m_max[idx]);\n      var dPrecip=daily.precipitation_probability_max[idx]||0;\n      var barLeft=dMin<dMax?Math.round((dLow-dMin)/(dMax-dMin)*100):0;\n      var barWidth=dMin<dMax?Math.round((dHigh-dLow)/(dMax-dMin)*100):50;\n      dailyHTML+='<div class=\"day-row\">'\n        +'<div class=\"day-name\">'+esc(dName)+'</div>'\n        +'<div class=\"day-icon\">'+dIcon+'</div>'\n        +'<div class=\"day-desc\">'+esc(dDesc)+'</div>'\n        +(dPrecip>0?'<div class=\"day-precip\">'+dPrecip+'%</div>':'<div class=\"day-precip\"></div>')\n        +'<div class=\"day-bar-wrap\">'\n          +'<div class=\"day-low\">'+dLow+'°</div>'\n          +'<div class=\"day-bar\"><div class=\"day-bar-fill\" style=\"left:'+barLeft+'%;width:'+barWidth+'%\"></div></div>'\n          +'<div class=\"day-high\">'+dHigh+'°</div>'\n        +'</div>'\n      +'</div>';\n    });\n  }\n  dailyHTML+='</div>';\n\n  // Extras\n  var uvLabel=['Low','Low','Low','Moderate','Moderate','Moderate','High','High','Very High','Very High','Extreme'][Math.min(Math.round(uv),10)];\n  var uvPct=Math.min(uv/11,1)*100;\n  var sunrise=daily&&daily.sunrise?new Date(daily.sunrise[0]).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'—';\n  var sunset=daily&&daily.sunset?new Date(daily.sunset[0]).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}):'—';\n  var extrasHTML='<div class=\"extras-grid\">'\n    +'<div class=\"extra-card\">'\n      +'<div class=\"extra-label\">☀️ UV Index</div>'\n      +'<div class=\"extra-val\">'+Math.round(uv)+'</div>'\n      +'<div class=\"extra-sub\">'+uvLabel+'</div>'\n      +'<div class=\"uv-bar\"><div class=\"uv-dot\" style=\"left:'+uvPct+'%\"></div></div>'\n    +'</div>'\n    +'<div class=\"extra-card\">'\n      +'<div class=\"extra-label\">👁️ Visibility</div>'\n      +'<div class=\"extra-val\">'+(vis!==null?vis+'km':'—')+'</div>'\n      +'<div class=\"extra-sub\">'+(vis===null?'':vis>10?'Crystal clear':vis>5?'Good':vis>2?'Moderate':'Poor')+'</div>'\n    +'</div>'\n    +'<div class=\"extra-card\">'\n      +'<div class=\"extra-label\">🌅 Sunrise</div>'\n      +'<div class=\"extra-val\" style=\"font-size:18px\">'+sunrise+'</div>'\n    +'</div>'\n    +'<div class=\"extra-card\">'\n      +'<div class=\"extra-label\">🌇 Sunset</div>'\n      +'<div class=\"extra-val\" style=\"font-size:18px\">'+sunset+'</div>'\n    +'</div>'\n  +'</div>';\n\n  document.getElementById('mainContent').innerHTML=heroHTML+hourlyHTML+dailyHTML+'<div class=\"section-card\"><div class=\"section-title\">📊 Details</div>'+extrasHTML+'</div><div style=\"height:20px\"></div>';\n}\n\nfunction showError(msg){\n  document.getElementById('mainContent').innerHTML='<div class=\"error-box\">⚠️ '+esc(msg)+'<br><button class=\"retry-btn\" onclick=\"init()\">↺ Retry</button></div>';\n}\n\nfunction openSearch(){\n  document.getElementById('searchBar').classList.add('open');\n  setTimeout(function(){document.getElementById('searchInput').focus();},50);\n}\nfunction closeSearch(){\n  document.getElementById('searchBar').classList.remove('open');\n  document.getElementById('searchInput').value='';\n}\nasync function doSearch(){\n  var q=document.getElementById('searchInput').value.trim();\n  if(!q)return;\n  closeSearch();\n  try{\n    var g=await geocode(q);\n    curLat=g.latitude;curLon=g.longitude;\n    curCity=g.name+(g.admin1?', '+g.admin1:'')+(g.country?', '+g.country:'');\n    await loadWeather(curLat,curLon,curCity);\n  }catch(e){\n    toast('⚠️ '+e.message);\n  }\n}\nfunction toast(msg){\n  var t=document.getElementById('toast');\n  t.textContent=msg;t.classList.add('show');\n  clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},2200);\n}\nfunction esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}\ninit();\n</script>\n</body>\n</html>"}
