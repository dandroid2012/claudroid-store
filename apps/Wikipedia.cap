{"name": "Wikipedia", "icon": "<svg viewBox=\"0 0 32 32\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"16\" cy=\"16\" r=\"15\" fill=\"#1a1a1a\" stroke=\"#f8f9fa\" stroke-width=\"1.5\"/><text x=\"16\" y=\"22\" font-size=\"18\" font-family=\"Linux Libertine,Georgia,serif\" text-anchor=\"middle\" fill=\"#f8f9fa\">W</text></svg>", "desc": "Wikipedia reader — search, browse featured articles, explore topics. Supports 10 languages. Uses the official Wikipedia REST API.", "version": "v1.0", "capVersion": "1", "codename": "com.claudroid.wikipedia", "color": "#1a1a1a", "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\">\n<style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}\n:root{\n  --bg:#0d0d0d;--s1:#161616;--s2:#222;--s3:#2d2d2d;\n  --text:#f8f9fa;--t2:#9aa0a6;--t3:#5f6368;\n  --accent:#3b82f6;--border:rgba(255,255,255,.08);--r:12px;\n}\nhtml,body{height:100%;overflow:hidden;background:var(--bg)}\nbody{display:flex;flex-direction:column;font-family:-apple-system,system-ui,sans-serif;color:var(--text)}\n\n/* TOPBAR */\n.topbar{height:50px;background:var(--s1);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 12px;gap:10px;flex-shrink:0}\n.wiki-logo{width:28px;height:28px;flex-shrink:0}\n.topbar-title{font-size:15px;font-weight:800;flex:1}\n.topbar-btn{width:32px;height:32px;border-radius:8px;background:transparent;border:none;color:var(--t2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px}\n.topbar-btn:active{background:var(--s2)}\n\n/* SEARCH */\n.search-bar{display:flex;align-items:center;gap:8px;padding:10px 12px;background:var(--s1);border-bottom:1px solid var(--border);flex-shrink:0}\n.search-wrap-inner{flex:1;display:flex;align-items:center;background:var(--s2);border:1px solid var(--border);border-radius:22px;padding:0 14px;gap:8px;transition:border-color .15s}\n.search-wrap-inner:focus-within{border-color:var(--accent)}\n.search-wrap-inner svg{width:15px;height:15px;flex-shrink:0;stroke:var(--t3)}\n.search-input{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-size:14px;font-family:inherit;padding:8px 0}\n.search-input::placeholder{color:var(--t3)}\n.search-clear{background:transparent;border:none;color:var(--t3);cursor:pointer;font-size:16px;padding:2px;line-height:1;display:none}\n.search-clear.show{display:block}\n\n/* SUGGESTIONS */\n.suggestions{position:absolute;top:100%;left:0;right:0;background:var(--s1);border-bottom:1px solid var(--border);z-index:50;max-height:220px;overflow-y:auto;display:none}\n.suggestions.show{display:block}\n.sug-item{padding:10px 14px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border)}\n.sug-item:last-child{border:none}\n.sug-item:active{background:var(--s2)}\n.sug-item svg{width:14px;height:14px;flex-shrink:0;stroke:var(--t3)}\n.search-container{position:relative;flex:1}\n\n/* MAIN */\n.main{flex:1;overflow-y:auto;background:var(--bg);position:relative}\n.main::-webkit-scrollbar{width:3px}\n.main::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px}\n\n/* HOME */\n.home-screen{padding:16px}\n.wiki-wordmark{font-size:28px;font-weight:300;letter-spacing:-1px;margin-bottom:4px;color:var(--text)}\n.wiki-tagline{font-size:12px;color:var(--t2);margin-bottom:20px}\n.featured-label{font-size:10px;font-weight:800;color:var(--t2);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}\n.featured-card{background:var(--s1);border-radius:var(--r);overflow:hidden;margin-bottom:16px;cursor:pointer;border:1px solid var(--border);transition:background .15s}\n.featured-card:active{background:var(--s2)}\n.featured-img{width:100%;height:120px;object-fit:cover;display:block;background:var(--s2)}\n.featured-body{padding:12px}\n.featured-title{font-size:14px;font-weight:700;margin-bottom:4px}\n.featured-excerpt{font-size:12px;color:var(--t2);line-height:1.5;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}\n.topics-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px}\n.topic-btn{background:var(--s1);border:1px solid var(--border);border-radius:var(--r);padding:12px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:8px;transition:background .15s}\n.topic-btn:active{background:var(--s2)}\n.topic-ico{font-size:20px;flex-shrink:0}\n.topic-label{font-size:12px;font-weight:700;color:var(--text)}\n\n/* RESULTS */\n.results-list{padding:8px 0}\n.result-item{padding:12px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s}\n.result-item:active{background:var(--s2)}\n.result-title{font-size:14px;font-weight:700;margin-bottom:3px}\n.result-desc{font-size:12px;color:var(--t2);line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}\n.result-thumb{width:52px;height:52px;border-radius:8px;object-fit:cover;float:right;margin-left:10px;background:var(--s2)}\n\n/* ARTICLE */\n.article-screen{position:absolute;inset:0;background:var(--bg);overflow-y:auto;transform:translateX(100%);transition:transform .25s cubic-bezier(.4,0,.2,1);z-index:10}\n.article-screen.open{transform:translateX(0)}\n.article-screen::-webkit-scrollbar{width:3px}\n.article-screen::-webkit-scrollbar-thumb{background:var(--s3)}\n.article-header{padding:16px 14px 0;position:sticky;top:0;background:var(--bg);border-bottom:1px solid var(--border);z-index:5;display:flex;align-items:center;gap:8px}\n.art-back{background:transparent;border:none;color:var(--t2);font-size:18px;cursor:pointer;padding:4px 8px 4px 0;line-height:1;flex-shrink:0}\n.art-title-bar{font-size:14px;font-weight:700;flex:1;padding-bottom:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}\n.art-actions{display:flex;gap:4px;padding-bottom:12px}\n.art-action{background:transparent;border:none;color:var(--t2);cursor:pointer;font-size:14px;padding:4px;line-height:1}\n.article-img{width:100%;max-height:220px;object-fit:cover;display:block;background:var(--s2)}\n.article-body{padding:14px}\n.article-title{font-size:20px;font-weight:700;margin-bottom:4px;line-height:1.3}\n.article-desc{font-size:13px;color:var(--t2);margin-bottom:12px;font-style:italic}\n.article-text{font-size:14px;line-height:1.7;color:var(--text)}\n.article-text p{margin-bottom:12px}\n.article-text h2{font-size:16px;font-weight:700;margin:16px 0 6px;padding-top:8px;border-top:1px solid var(--border);color:var(--text)}\n.article-text h3{font-size:14px;font-weight:700;margin:12px 0 4px}\n.article-text a{color:var(--accent);text-decoration:none}\n.article-text ul,.article-text ol{margin:8px 0 8px 18px}\n.article-text li{margin-bottom:4px}\n.article-text b,.article-text strong{font-weight:700;color:#fff}\n.article-text i,.article-text em{font-style:italic}\n.read-more-btn{display:block;width:100%;margin-top:8px;padding:12px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r);color:var(--accent);font-family:inherit;font-weight:700;font-size:13px;cursor:pointer;text-align:center}\n.open-full-btn{display:flex;align-items:center;justify-content:center;gap:6px;margin:12px 14px;background:transparent;border:1px solid var(--border);border-radius:var(--r);padding:10px;color:var(--t2);font-family:inherit;font-size:12px;cursor:pointer;font-weight:600}\n\n/* LOADING */\n.loader{padding:40px;text-align:center;color:var(--t2);font-size:13px}\n.spinner{width:28px;height:28px;border:2px solid var(--s3);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 12px}\n@keyframes spin{to{transform:rotate(360deg)}}\n.error-box{margin:16px;background:var(--s1);border-radius:var(--r);padding:20px;text-align:center;border:1px solid var(--border)}\n.error-box p{font-size:13px;color:var(--t2);margin-bottom:12px}\n.retry-btn{background:var(--accent);border:none;color:#fff;border-radius:8px;padding:8px 18px;font-family:inherit;font-weight:700;font-size:13px;cursor:pointer}\n\n/* LANGUAGE */\n.lang-pills{display:flex;gap:6px;overflow-x:auto;padding:8px 12px;background:var(--s1);border-bottom:1px solid var(--border);flex-shrink:0;scrollbar-width:none}\n.lang-pills::-webkit-scrollbar{display:none}\n.lang-pill{background:var(--s2);border:1px solid var(--border);border-radius:14px;padding:4px 10px;font-size:11px;font-weight:700;color:var(--t2);cursor:pointer;white-space:nowrap;flex-shrink:0}\n.lang-pill.active{background:rgba(59,130,246,.15);border-color:var(--accent);color:var(--accent)}\n</style>\n</head>\n<body>\n\n<!-- TOPBAR -->\n<div class=\"topbar\">\n  <svg class=\"wiki-logo\" viewBox=\"0 0 50 50\" xmlns=\"http://www.w3.org/2000/svg\">\n    <circle cx=\"25\" cy=\"25\" r=\"24\" fill=\"none\" stroke=\"#f8f9fa\" stroke-width=\"2\"/>\n    <text x=\"25\" y=\"34\" font-size=\"28\" font-family=\"Linux Libertine,Georgia,serif\" text-anchor=\"middle\" fill=\"#f8f9fa\">W</text>\n  </svg>\n  <span class=\"topbar-title\">Wikipedia</span>\n  <button class=\"topbar-btn\" onclick=\"goHome()\">⌂</button>\n</div>\n\n<!-- LANG PILLS -->\n<div class=\"lang-pills\">\n  <div class=\"lang-pill active\" onclick=\"setLang('en',this)\">EN</div>\n  <div class=\"lang-pill\" onclick=\"setLang('es',this)\">ES</div>\n  <div class=\"lang-pill\" onclick=\"setLang('fr',this)\">FR</div>\n  <div class=\"lang-pill\" onclick=\"setLang('de',this)\">DE</div>\n  <div class=\"lang-pill\" onclick=\"setLang('ru',this)\">RU</div>\n  <div class=\"lang-pill\" onclick=\"setLang('zh',this)\">ZH</div>\n  <div class=\"lang-pill\" onclick=\"setLang('ja',this)\">JA</div>\n  <div class=\"lang-pill\" onclick=\"setLang('ar',this)\">AR</div>\n  <div class=\"lang-pill\" onclick=\"setLang('pt',this)\">PT</div>\n  <div class=\"lang-pill\" onclick=\"setLang('it',this)\">IT</div>\n</div>\n\n<!-- SEARCH BAR -->\n<div class=\"search-bar\">\n  <div class=\"search-container\">\n    <div class=\"search-wrap-inner\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg>\n      <input class=\"search-input\" id=\"searchInput\" placeholder=\"Search Wikipedia…\"\n        oninput=\"onSearchInput(this.value)\"\n        onkeydown=\"if(event.key==='Enter')doSearch(this.value)\">\n      <button class=\"search-clear\" id=\"clearBtn\" onclick=\"clearSearch()\">✕</button>\n    </div>\n    <div class=\"suggestions\" id=\"suggestions\"></div>\n  </div>\n</div>\n\n<!-- MAIN AREA -->\n<div class=\"main\" id=\"main\">\n  <div class=\"home-screen\" id=\"homeScreen\">\n    <div class=\"wiki-wordmark\">Wikipedia</div>\n    <div class=\"wiki-tagline\">The free encyclopedia</div>\n\n    <div class=\"featured-label\">Featured Article</div>\n    <div class=\"featured-card\" id=\"featuredCard\">\n      <div class=\"loader\"><div class=\"spinner\"></div>Loading…</div>\n    </div>\n\n    <div class=\"featured-label\">Explore Topics</div>\n    <div class=\"topics-grid\">\n      <button class=\"topic-btn\" onclick=\"doSearch('Science')\"><div class=\"topic-ico\">\\U0001f52c</div><div class=\"topic-label\">Science</div></button>\n      <button class=\"topic-btn\" onclick=\"doSearch('History')\"><div class=\"topic-ico\">\\U0001f3db</div><div class=\"topic-label\">History</div></button>\n      <button class=\"topic-btn\" onclick=\"doSearch('Technology')\"><div class=\"topic-ico\">\\U0001f4bb</div><div class=\"topic-label\">Technology</div></button>\n      <button class=\"topic-btn\" onclick=\"doSearch('Space')\"><div class=\"topic-ico\">\\U0001f680</div><div class=\"topic-label\">Space</div></button>\n      <button class=\"topic-btn\" onclick=\"doSearch('Art')\"><div class=\"topic-ico\">\\U0001f3a8</div><div class=\"topic-label\">Art</div></button>\n      <button class=\"topic-btn\" onclick=\"doSearch('Animals')\"><div class=\"topic-ico\">\\U0001f98a</div><div class=\"topic-label\">Animals</div></button>\n    </div>\n  </div>\n\n  <div id=\"resultsScreen\" style=\"display:none\"></div>\n\n  <!-- ARTICLE -->\n  <div class=\"article-screen\" id=\"articleScreen\">\n    <div class=\"article-header\">\n      <button class=\"art-back\" onclick=\"closeArticle()\">‹</button>\n      <div class=\"art-title-bar\" id=\"artTitleBar\"></div>\n      <div class=\"art-actions\">\n        <button class=\"art-action\" onclick=\"shareArticle()\" title=\"Share\">📤</button>\n      </div>\n    </div>\n    <div id=\"articleContent\"></div>\n  </div>\n</div>\n\n<script>\nvar lang = 'en';\nvar curArticleTitle = '';\nvar suggestTimer = null;\n\n// ── INIT ──\nloadFeatured();\n\nfunction setLang(l, el) {\n  lang = l;\n  document.querySelectorAll('.lang-pill').forEach(function(p){p.classList.remove('active');});\n  el.classList.add('active');\n  loadFeatured();\n}\n\n// ── FEATURED ──\nasync function loadFeatured() {\n  var card = document.getElementById('featuredCard');\n  card.innerHTML = '<div class=\"loader\"><div class=\"spinner\"></div>Loading…</div>';\n  try {\n    var today = new Date();\n    var y = today.getFullYear(), m = String(today.getMonth()+1).padStart(2,'0'), d = String(today.getDate()).padStart(2,'0');\n    var res = await fetch('https://' + lang + '.wikipedia.org/api/rest_v1/feed/featured/' + y + '/' + m + '/' + d);\n    if(!res.ok) throw new Error();\n    var data = await res.json();\n    var tfa = data.tfa;\n    if(!tfa) throw new Error();\n    var imgUrl = tfa.thumbnail ? tfa.thumbnail.source : '';\n    card.innerHTML = (imgUrl ? '<img class=\"featured-img\" src=\"' + esc(imgUrl) + '\" loading=\"lazy\" onerror=\"this.remove()\">' : '') +\n      '<div class=\"featured-body\"><div class=\"featured-title\">' + esc(tfa.normalizedtitle || tfa.title) + '</div>' +\n      '<div class=\"featured-excerpt\">' + esc((tfa.extract||'').slice(0,200)) + '</div></div>';\n    card.onclick = function(){ openArticle(tfa.normalizedtitle || tfa.title); };\n  } catch(e) {\n    // Fallback: load random article\n    loadRandomArticle(card);\n  }\n}\n\nasync function loadRandomArticle(card) {\n  try {\n    var res = await fetch('https://' + lang + '.wikipedia.org/api/rest_v1/page/random/summary');\n    if(!res.ok) throw new Error();\n    var data = await res.json();\n    var imgUrl = data.thumbnail ? data.thumbnail.source : '';\n    card.innerHTML = (imgUrl ? '<img class=\"featured-img\" src=\"' + esc(imgUrl) + '\" loading=\"lazy\" onerror=\"this.remove()\">' : '') +\n      '<div class=\"featured-body\"><div class=\"featured-title\">' + esc(data.title) + '</div>' +\n      '<div class=\"featured-excerpt\">' + esc((data.extract||'').slice(0,200)) + '</div></div>';\n    card.onclick = function(){ openArticle(data.title); };\n  } catch(e) {\n    card.innerHTML = '<div class=\"featured-body\"><div class=\"featured-title\">Explore Wikipedia</div><div class=\"featured-excerpt\">Search for any topic above to get started.</div></div>';\n  }\n}\n\n// ── SEARCH ──\nfunction onSearchInput(v) {\n  document.getElementById('clearBtn').classList.toggle('show', v.length > 0);\n  clearTimeout(suggestTimer);\n  if(v.length < 2){ hideSuggestions(); return; }\n  suggestTimer = setTimeout(function(){ fetchSuggestions(v); }, 300);\n}\n\nasync function fetchSuggestions(q) {\n  try {\n    var res = await fetch('https://' + lang + '.wikipedia.org/w/api.php?action=opensearch&format=json&origin=*&limit=6&search=' + encodeURIComponent(q));\n    var data = await res.json();\n    var titles = data[1] || [];\n    var descs = data[2] || [];\n    showSuggestions(titles, descs);\n  } catch(e) {}\n}\n\nfunction showSuggestions(titles, descs) {\n  var box = document.getElementById('suggestions');\n  if(!titles.length){ hideSuggestions(); return; }\n  box.innerHTML = '';\n  titles.forEach(function(t, i) {\n    var el = document.createElement('div');\n    el.className = 'sug-item';\n    el.innerHTML = '<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke-width=\"2\" stroke-linecap=\"round\"><circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/></svg>' +\n      '<span>' + esc(t) + (descs[i] ? '<br><small style=\"color:var(--t3)\">' + esc(descs[i].slice(0,60)) + '</small>' : '') + '</span>';\n    el.onclick = function() { hideSuggestions(); openArticle(t); };\n    box.appendChild(el);\n  });\n  box.classList.add('show');\n}\n\nfunction hideSuggestions() {\n  document.getElementById('suggestions').classList.remove('show');\n}\n\nfunction clearSearch() {\n  document.getElementById('searchInput').value = '';\n  document.getElementById('clearBtn').classList.remove('show');\n  hideSuggestions();\n  document.getElementById('resultsScreen').style.display = 'none';\n  document.getElementById('homeScreen').style.display = '';\n}\n\nasync function doSearch(q) {\n  if(!q) q = document.getElementById('searchInput').value.trim();\n  if(!q) return;\n  document.getElementById('searchInput').value = q;\n  document.getElementById('clearBtn').classList.add('show');\n  hideSuggestions();\n  document.getElementById('homeScreen').style.display = 'none';\n  var rs = document.getElementById('resultsScreen');\n  rs.style.display = '';\n  rs.innerHTML = '<div class=\"loader\"><div class=\"spinner\"></div>Searching…</div>';\n  try {\n    var res = await fetch('https://' + lang + '.wikipedia.org/w/api.php?action=query&format=json&origin=*&list=search&srsearch=' + encodeURIComponent(q) + '&srlimit=20&prop=pageimages&piprop=thumbnail&pithumbsize=80');\n    var data = await res.json();\n    var results = data.query.search;\n    if(!results.length) { rs.innerHTML = '<div class=\"error-box\"><p>No results for \"' + esc(q) + '\"</p></div>'; return; }\n    rs.innerHTML = '<div class=\"results-list\"></div>';\n    var list = rs.querySelector('.results-list');\n    results.forEach(function(r) {\n      var el = document.createElement('div');\n      el.className = 'result-item';\n      var snippet = r.snippet.replace(/<[^>]+>/g,'').replace(/&quot;/g,'\"').replace(/&amp;/g,'&');\n      el.innerHTML = '<div class=\"result-title\">' + esc(r.title) + '</div><div class=\"result-desc\">' + esc(snippet.slice(0,120)) + '</div>';\n      el.onclick = function(){ openArticle(r.title); };\n      list.appendChild(el);\n    });\n  } catch(e) {\n    rs.innerHTML = '<div class=\"error-box\"><p>Search failed<br><small>' + esc(e.message) + '</small></p><button class=\"retry-btn\" onclick=\"doSearch(\\'' + esc(q) + '\\')\">↺ Retry</button></div>';\n  }\n}\n\n// ── ARTICLE ──\nasync function openArticle(title) {\n  curArticleTitle = title;\n  hideSuggestions();\n  var screen = document.getElementById('articleScreen');\n  var content = document.getElementById('articleContent');\n  document.getElementById('artTitleBar').textContent = title;\n  screen.classList.add('open');\n  content.innerHTML = '<div class=\"loader\"><div class=\"spinner\"></div>Loading article…</div>';\n  try {\n    var res = await fetch('https://' + lang + '.wikipedia.org/api/rest_v1/page/summary/' + encodeURIComponent(title.replace(/ /g,'_')));\n    if(!res.ok) throw new Error('HTTP ' + res.status);\n    var data = await res.json();\n    renderArticleSummary(data);\n    // Also load full content sections\n    loadArticleSections(title, data);\n  } catch(e) {\n    content.innerHTML = '<div class=\"error-box\"><p>Couldn\\'t load article<br><small>' + esc(e.message) + '</small></p><button class=\"retry-btn\" onclick=\"openArticle(\\'' + esc(title) + '\\')\">↺ Retry</button></div>';\n  }\n}\n\nfunction renderArticleSummary(data) {\n  var content = document.getElementById('articleContent');\n  var imgHtml = '';\n  if(data.thumbnail) imgHtml = '<img class=\"article-img\" src=\"' + esc(data.thumbnail.source) + '\" loading=\"lazy\" onerror=\"this.remove()\">';\n  content.innerHTML = imgHtml +\n    '<div class=\"article-body\">' +\n      '<div class=\"article-title\">' + esc(data.title) + '</div>' +\n      (data.description ? '<div class=\"article-desc\">' + esc(data.description) + '</div>' : '') +\n      '<div class=\"article-text\" id=\"articleText\"><p>' + esc(data.extract||'') + '</p><div class=\"loader\" id=\"sectionsLoader\"><div class=\"spinner\"></div>Loading full article…</div></div>' +\n    '</div>' +\n    '<button class=\"open-full-btn\" onclick=\"openInBrowser()\">🌐 Open full article on Wikipedia</button>';\n}\n\nasync function loadArticleSections(title, summaryData) {\n  try {\n    var res = await fetch('https://' + lang + '.wikipedia.org/w/api.php?action=query&format=json&origin=*&prop=extracts&exintro=false&explaintext=false&exsectionformat=wiki&titles=' + encodeURIComponent(title) + '&redirects=1');\n    var data = await res.json();\n    var pages = data.query.pages;\n    var page = pages[Object.keys(pages)[0]];\n    var loader = document.getElementById('sectionsLoader');\n    if(loader) loader.remove();\n    if(!page || !page.extract) return;\n    var textEl = document.getElementById('articleText');\n    if(!textEl) return;\n    // Convert wikitext sections to HTML\n    var html = wikiToHtml(page.extract);\n    textEl.innerHTML = html;\n  } catch(e) {\n    var loader = document.getElementById('sectionsLoader');\n    if(loader) loader.remove();\n  }\n}\n\nfunction wikiToHtml(text) {\n  if(!text) return '';\n  // Split into lines and process\n  var lines = text.split('\\n');\n  var html = '';\n  var inList = false;\n  for(var i=0;i<lines.length;i++){\n    var line = lines[i];\n    if(!line.trim()){ if(inList){html+='</ul>';inList=false;} continue; }\n    // Headers\n    if(line.startsWith('==') && line.endsWith('==')){\n      var level = line.match(/^(=+)/)[1].length;\n      var htext = line.replace(/^=+\\s*|\\s*=+$/g,'');\n      if(inList){html+='</ul>';inList=false;}\n      html += '<h' + Math.min(level,3) + '>' + esc(htext) + '</h' + Math.min(level,3) + '>';\n    } else if(line.startsWith('*')){\n      if(!inList){html+='<ul>';inList=true;}\n      html += '<li>' + esc(line.replace(/^\\*+\\s*/,'')) + '</li>';\n    } else {\n      if(inList){html+='</ul>';inList=false;}\n      html += '<p>' + esc(line) + '</p>';\n    }\n  }\n  if(inList) html+='</ul>';\n  return html;\n}\n\nfunction closeArticle() {\n  document.getElementById('articleScreen').classList.remove('open');\n}\n\nfunction openInBrowser() {\n  var url = 'https://' + lang + '.wikipedia.org/wiki/' + encodeURIComponent(curArticleTitle.replace(/ /g,'_'));\n  window.open(url, '_blank');\n}\n\nfunction shareArticle() {\n  var url = 'https://' + lang + '.wikipedia.org/wiki/' + encodeURIComponent(curArticleTitle.replace(/ /g,'_'));\n  if(navigator.clipboard) navigator.clipboard.writeText(url).then(function(){showToast('Link copied!');});\n  else showToast(url.slice(0,40)+'…');\n}\n\nfunction goHome() {\n  closeArticle();\n  hideSuggestions();\n  document.getElementById('searchInput').value = '';\n  document.getElementById('clearBtn').classList.remove('show');\n  document.getElementById('resultsScreen').style.display = 'none';\n  document.getElementById('homeScreen').style.display = '';\n}\n\nfunction showToast(msg){\n  var t=document.getElementById('_toast');\n  if(!t){t=document.createElement('div');t.id='_toast';t.style.cssText='position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:var(--s2);border:1px solid var(--border);border-radius:20px;padding:7px 16px;font-size:12px;font-weight:600;color:var(--t2);opacity:0;transition:opacity .2s;pointer-events:none;z-index:999;white-space:nowrap';document.body.appendChild(t);}\n  t.textContent=msg;t.style.opacity='1';\n  clearTimeout(t._t);t._t=setTimeout(function(){t.style.opacity='0';},2200);\n}\n\nfunction esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}\n</script>\n</body>\n</html>"}