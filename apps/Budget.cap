{"id": "com.claudroid.budget", "name": "Budget", "desc": "Personal budget tracker. Add income and expenses by category, see balance and spending breakdown. Saved locally.", "icon": "💰", "color": "#0a1e0a", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box}body{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}.hdr{background:#0e1117;border-bottom:1px solid #1c2333;padding:14px 16px;flex-shrink:0}.bal-lbl{font-size:10px;font-weight:800;color:#6b7a99;text-transform:uppercase;letter-spacing:.6px;margin-bottom:4px}.bal{font-size:34px;font-weight:200;letter-spacing:-1px}.summary{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px}.sum-box{background:#0e1117;border:1px solid #1c2333;border-radius:12px;padding:10px 12px}.sum-lbl{font-size:10px;color:#6b7a99;font-weight:800;text-transform:uppercase;letter-spacing:.5px}.sum-val{font-size:18px;font-weight:800;margin-top:3px}.list{flex:1;overflow-y:auto;padding:12px 14px}.entry{background:#0e1117;border:1px solid #1c2333;border-radius:14px;padding:11px 13px;display:flex;align-items:center;gap:10px;margin-bottom:8px}.e-ico{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}.e-info{flex:1;min-width:0}.e-desc{font-size:13px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.e-cat{font-size:11px;color:#6b7a99;margin-top:2px}.e-amt{font-size:15px;font-weight:800;flex-shrink:0}.e-del{background:none;border:none;color:#3d4a63;font-size:16px;cursor:pointer;padding:4px}.e-del:active{color:#f87171}.add-area{background:#0e1117;border-top:1px solid #1c2333;padding:12px 14px;display:flex;flex-direction:column;gap:8px;flex-shrink:0}.type-row{display:flex;gap:6px}.t-btn{flex:1;padding:8px;border-radius:10px;border:1px solid #1c2333;background:#07090f;color:#6b7a99;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit}.t-btn.inc{border-color:rgba(52,211,153,.4);color:#34d399;background:rgba(52,211,153,.08)}.t-btn.exp{border-color:rgba(248,113,113,.4);color:#f87171;background:rgba(248,113,113,.08)}.inp-row{display:flex;gap:8px}.inp{flex:1;background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:9px 11px;font-size:13px;color:#e2e8f8;font-family:inherit;outline:none}.inp:focus{border-color:#34d399}.inp.sm{width:90px;flex:none}.sel{background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:9px;font-size:12px;color:#e2e8f8;font-family:inherit;outline:none}.add{background:#34d399;border:none;color:#07090f;border-radius:10px;padding:9px 14px;font-size:13px;font-weight:800;cursor:pointer;font-family:inherit}</style><div class=\"hdr\"><div class=\"bal-lbl\">Balance</div><div class=\"bal\" id=\"bal\">$0.00</div><div class=\"summary\"><div class=\"sum-box\"><div class=\"sum-lbl\">Income</div><div class=\"sum-val\" style=\"color:#34d399\" id=\"inc\">$0.00</div></div><div class=\"sum-box\"><div class=\"sum-lbl\">Expenses</div><div class=\"sum-val\" style=\"color:#f87171\" id=\"exp\">$0.00</div></div></div></div><div class=\"list\" id=\"list\"></div><div class=\"add-area\"><div class=\"type-row\"><button class=\"t-btn\" id=\"tInc\" onclick=\"setType('income')\">+ Income</button><button class=\"t-btn exp\" id=\"tExp\" onclick=\"setType('expense')\">− Expense</button></div><div class=\"inp-row\"><input class=\"inp\" id=\"desc\" placeholder=\"Description…\"><input class=\"inp sm\" id=\"amt\" type=\"number\" placeholder=\"0.00\" min=\"0\" step=\"0.01\"><select class=\"sel\" id=\"cat\"><option>🍔 Food</option><option>🚗 Transport</option><option>🏠 Housing</option><option>🛍 Shopping</option><option>💊 Health</option><option>🎮 Fun</option><option>📚 Edu</option><option>💼 Work</option><option>📦 Other</option></select><button class=\"add\" onclick=\"addEntry()\">Add</button></div></div><script>var entries=[],entryType='expense';try{entries=JSON.parse(localStorage.getItem('claudroid_budget')||'[]');}catch(e){}function setType(t){entryType=t;document.getElementById('tInc').className='t-btn'+(t==='income'?' inc':'');document.getElementById('tExp').className='t-btn'+(t==='expense'?' exp':'');}function render(){var inc=0,exp=0;entries.forEach(function(e){if(e.t==='income')inc+=e.a;else exp+=e.a;});var b=inc-exp;document.getElementById('bal').textContent=(b<0?'-':'')+'$'+Math.abs(b).toFixed(2);document.getElementById('bal').style.color=b<0?'#f87171':b>0?'#34d399':'#e2e8f8';document.getElementById('inc').textContent='$'+inc.toFixed(2);document.getElementById('exp').textContent='$'+exp.toFixed(2);var el=document.getElementById('list');if(!entries.length){el.innerHTML='<div style=\"text-align:center;padding:40px;color:#3d4a63;font-size:13px\">No entries yet.</div>';return;}el.innerHTML=entries.slice().reverse().map(function(e,i){var ri=entries.length-1-i;var p=e.c.split(' ');return'<div class=\"entry\"><div class=\"e-ico\" style=\"background:'+(e.t==='income'?'rgba(52,211,153,.1)':'rgba(248,113,113,.1)')+'\">'+p[0]+'</div><div class=\"e-info\"><div class=\"e-desc\">'+e.d+'</div><div class=\"e-cat\">'+p.slice(1).join(' ')+'</div></div><div class=\"e-amt\" style=\"color:'+(e.t==='income'?'#34d399':'#f87171')+'\">'+(e.t==='income'?'+':'-')+'$'+e.a.toFixed(2)+'</div><button class=\"e-del\" onclick=\"del('+ri+')\">×</button></div>';}).join('');}function addEntry(){var d=document.getElementById('desc').value.trim(),a=parseFloat(document.getElementById('amt').value),c=document.getElementById('cat').value;if(!d||isNaN(a)||a<=0)return;entries.push({t:entryType,d:d,a:a,c:c});save();document.getElementById('desc').value='';document.getElementById('amt').value='';}function del(i){if(!confirm('Delete?'))return;entries.splice(i,1);save();}function save(){try{localStorage.setItem('claudroid_budget',JSON.stringify(entries));}catch(e){}render();}setType('expense');render();</script>"}