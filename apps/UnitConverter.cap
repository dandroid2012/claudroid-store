{"id": "com.claudroid.unitconverter", "name": "Unit Converter", "desc": "Convert length, weight, temperature, speed, area, volume, time and data. Fully offline.", "icon": "рџ“ђ", "color": "#0a1a2e", "version": "v1.0", "html": "<style>*{margin:0;box-sizing:border-box}body{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;height:100vh;display:flex;flex-direction:column;overflow:hidden}.top{background:#0e1117;border-bottom:1px solid #1c2333;padding:10px 14px;flex-shrink:0}.cats{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;padding-bottom:2px}.cat{flex-shrink:0;padding:6px 13px;border-radius:20px;border:1px solid #1c2333;background:#0e1117;color:#6b7a99;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit;white-space:nowrap}.cat.active{background:rgba(79,142,247,.18);color:#4f8ef7;border-color:rgba(79,142,247,.3)}.body{flex:1;padding:16px 14px;display:flex;flex-direction:column;gap:12px;overflow-y:auto}.field{background:#0e1117;border:1px solid #1c2333;border-radius:16px;padding:12px 14px}.label{font-size:10px;font-weight:800;color:#6b7a99;text-transform:uppercase;letter-spacing:.6px;margin-bottom:6px}.row{display:flex;gap:8px}.inp{flex:1;background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:10px 12px;font-size:22px;font-weight:700;color:#e2e8f8;font-family:inherit;outline:none;min-width:0}.inp:focus{border-color:#4f8ef7}.sel{flex:1;background:#07090f;border:1px solid #1c2333;border-radius:10px;padding:9px;font-size:13px;color:#e2e8f8;font-family:inherit;outline:none;min-width:0}.swap{background:#1c2333;border:none;color:#4f8ef7;border-radius:12px;padding:10px 14px;font-size:18px;cursor:pointer}.result{background:rgba(79,142,247,.08);border:1px solid rgba(79,142,247,.2);border-radius:16px;padding:16px;text-align:center}.result-val{font-size:30px;font-weight:800;color:#4f8ef7;word-break:break-all}.result-lbl{font-size:12px;color:#6b7a99;margin-top:4px}</style><div class=\"top\"><div class=\"cats\" id=\"cats\"></div></div><div class=\"body\"><div class=\"field\"><div class=\"label\">From</div><div class=\"row\"><input class=\"inp\" id=\"fromVal\" type=\"number\" value=\"1\" oninput=\"conv()\"><select class=\"sel\" id=\"fromU\" onchange=\"conv()\"></select></div></div><div style=\"text-align:center\"><button class=\"swap\" onclick=\"swap()\">в‡…</button></div><div class=\"field\"><div class=\"label\">To</div><div class=\"row\"><select class=\"sel\" id=\"toU\" onchange=\"conv()\"></select></div></div><div class=\"result\"><div class=\"result-val\" id=\"res\">вЂ”</div><div class=\"result-lbl\" id=\"resLbl\"></div></div></div><script>var C={Length:{u:{m:1,km:1e3,cm:.01,mm:.001,mi:1609.34,yd:.9144,ft:.3048,in:.0254},l:{m:'Metre',km:'Kilometre',cm:'Centimetre',mm:'Millimetre',mi:'Mile',yd:'Yard',ft:'Foot',in:'Inch'}},Weight:{u:{kg:1,g:.001,mg:1e-6,lb:.45359,oz:.02835,t:1000},l:{kg:'Kilogram',g:'Gram',mg:'Milligram',lb:'Pound',oz:'Ounce',t:'Tonne'}},Temp:{special:true,l:{C:'Celsius',F:'Fahrenheit',K:'Kelvin'}},Speed:{u:{'m/s':1,'km/h':.27778,'mph':.44704,'kn':.51444},l:{'m/s':'m/sec','km/h':'km/h','mph':'mph','kn':'Knots'}},Area:{u:{'m2':1,'km2':1e6,'cm2':.0001,ha:1e4,'ft2':.0929,ac:4046.86},l:{'m2':'mВІ','km2':'kmВІ','cm2':'cmВІ',ha:'Hectare','ft2':'ftВІ',ac:'Acre'}},Volume:{u:{L:1,mL:.001,m3:1000,gal:3.785,qt:.946,pt:.473,cup:.24},l:{L:'Litre',mL:'mL',m3:'mВі',gal:'Gallon',qt:'Quart',pt:'Pint',cup:'Cup'}},Time:{u:{s:1,min:60,h:3600,d:86400,wk:604800,mo:2629800,yr:31557600,ms:.001},l:{s:'Second',min:'Minute',h:'Hour',d:'Day',wk:'Week',mo:'Month',yr:'Year',ms:'Millisecond'}},Data:{u:{B:1,KB:1024,MB:1048576,GB:1073741824,TB:1.0995e12,b:.125},l:{B:'Byte',KB:'KB',MB:'MB',GB:'GB',TB:'TB',b:'Bit'}}};var cur='Length';function buildCats(){document.getElementById('cats').innerHTML=Object.keys(C).map(function(k){return'<button class=\"cat'+(k===cur?' active':'')+'\" onclick=\"setCat(''+k+'')\">'+ ({'Length':'рџ“Џ','Weight':'вљ–пёЏ','Temp':'рџЊЎпёЏ','Speed':'рџљЂ','Area':'рџ—є','Volume':'рџ§Є','Time':'вЏ±','Data':'рџ’ѕ'}[k]||'')+ ' '+k+'</button>';}).join('');}function buildUnits(){var cat=C[cur];var keys=cat.special?Object.keys(cat.l):Object.keys(cat.u);function opts(id,def){document.getElementById(id).innerHTML=keys.map(function(k){return'<option value=\"'+k+'\">'+(cat.l[k]||k)+' ('+k+')</option>';}).join('');document.getElementById(id).value=def||keys[0];}opts('fromU',keys[0]);opts('toU',keys[1]||keys[0]);}function setCat(c){cur=c;buildCats();buildUnits();document.getElementById('fromVal').value=1;conv();}function conv(){var v=parseFloat(document.getElementById('fromVal').value);var fu=document.getElementById('fromU').value,tu=document.getElementById('toU').value;var cat=C[cur];if(isNaN(v)){document.getElementById('res').textContent='вЂ”';return;}var r;if(cat.special){var c=fu==='F'?(v-32)*5/9:fu==='K'?v-273.15:v;r=tu==='C'?c:tu==='F'?c*9/5+32:c+273.15;}else{r=v*cat.u[fu]/cat.u[tu];}var fmt=Math.abs(r)>=1e9?r.toExponential(4):(Math.abs(r)<.0001&&r!==0)?r.toExponential(4):parseFloat(r.toPrecision(8));document.getElementById('res').textContent=fmt;document.getElementById('resLbl').textContent=cat.l[tu]||tu;}function swap(){var f=document.getElementById('fromU'),t=document.getElementById('toU'),tmp=f.value;f.value=t.value;t.value=tmp;conv();}buildCats();buildUnits();conv();</script>"}