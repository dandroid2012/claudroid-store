{"name": "Minesweeper", "icon": "💣", "desc": "Classic Minesweeper. Click to reveal, long-press (mobile) or right-click to flag. 3 difficulty levels. Includes timer.", "version": "v1.0", "color": "#07090f", "html": "<!DOCTYPE html><html><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1,user-scalable=no\"><style>\n*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}\nbody{background:#07090f;color:#e2e8f8;font-family:system-ui,sans-serif;display:flex;flex-direction:column;align-items:center;min-height:100vh;padding:16px;user-select:none;touch-action:manipulation}\nh1{font-size:22px;font-weight:900;margin-bottom:10px}\n.topbar{display:flex;gap:12px;margin-bottom:12px;align-items:center}\n.box{background:#0e1117;border-radius:12px;padding:8px 16px;text-align:center;border:1px solid rgba(255,255,255,.07)}\n.box-val{font-size:20px;font-weight:800;font-family:monospace}\n.box-lbl{font-size:9px;color:#6b7a99;text-transform:uppercase;letter-spacing:.5px}\n.face-btn{background:#151b26;border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:8px 14px;font-size:20px;cursor:pointer}\n.face-btn:active{background:#1c2333}\n.diff-row{display:flex;gap:8px;margin-bottom:12px}\n.diff-btn{background:#151b26;border:1px solid rgba(255,255,255,.1);color:#e2e8f8;border-radius:10px;padding:7px 14px;font-family:inherit;font-size:12px;font-weight:700;cursor:pointer}\n.diff-btn.active{background:#4f8ef7;border-color:#4f8ef7;color:#fff}\n.grid{display:inline-grid;gap:3px;background:#0e1117;border-radius:14px;padding:10px;border:1px solid rgba(255,255,255,.07)}\n.cell{width:34px;height:34px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;cursor:pointer;background:#1c2333;border:1px solid rgba(255,255,255,.06);transition:background .1s}\n.cell:active{background:#253040}\n.cell.revealed{background:#0e1117;border-color:rgba(255,255,255,.04);cursor:default}\n.cell.flagged{background:#2a1a0a}\n.cell.mine{background:#2a0a0a}\n.cell.safe{background:#0a2a0a}\n.n1{color:#4f8ef7}.n2{color:#34d399}.n3{color:#f87171}.n4{color:#a78bfa}.n5{color:#f97316}.n6{color:#06b6d4}.n7{color:#ec4899}.n8{color:#e2e8f8}\n.msg{font-size:13px;color:#6b7a99;margin-top:10px;text-align:center;min-height:20px}\n</style></head><body>\n<h1>💣 Minesweeper</h1>\n<div class=\"topbar\">\n  <div class=\"box\"><div class=\"box-val\" id=\"mineCount\">0</div><div class=\"box-lbl\">Mines</div></div>\n  <button class=\"face-btn\" id=\"faceBtn\" onclick=\"newGame()\">😊</button>\n  <div class=\"box\"><div class=\"box-val\" id=\"timerDisp\">0</div><div class=\"box-lbl\">Seconds</div></div>\n</div>\n<div class=\"diff-row\">\n  <button class=\"diff-btn active\" id=\"dEasy\" onclick=\"setDiff('easy')\">Easy</button>\n  <button class=\"diff-btn\" id=\"dMedium\" onclick=\"setDiff('medium')\">Medium</button>\n  <button class=\"diff-btn\" id=\"dHard\" onclick=\"setDiff('hard')\">Hard</button>\n</div>\n<div class=\"grid\" id=\"grid\"></div>\n<div class=\"msg\" id=\"msg\">Left-click to reveal • Long press to flag</div>\n<script>\nconst DIFFS={easy:{rows:9,cols:9,mines:10},medium:{rows:12,cols:12,mines:20},hard:{rows:14,cols:14,mines:35}};\nlet diff='easy',rows,cols,mines,board,revealed,flagged,gameOver,started,timer,seconds,firstClick=true;\n\nfunction setDiff(d){\n  diff=d;['easy','medium','hard'].forEach(x=>{document.getElementById('d'+x.charAt(0).toUpperCase()+x.slice(1)).classList.toggle('active',x===d);});\n  newGame();\n}\n\nfunction newGame(){\n  clearInterval(timer);\n  const cfg=DIFFS[diff];rows=cfg.rows;cols=cfg.cols;mines=cfg.mines;\n  board=Array(rows*cols).fill(0);\n  revealed=Array(rows*cols).fill(false);\n  flagged=Array(rows*cols).fill(false);\n  gameOver=false;started=false;firstClick=true;seconds=0;\n  document.getElementById('mineCount').textContent=mines;\n  document.getElementById('timerDisp').textContent=0;\n  document.getElementById('faceBtn').textContent='😊';\n  document.getElementById('msg').textContent='Left-click to reveal • Long press to flag';\n  renderGrid();\n}\n\nfunction placeMines(firstIdx){\n  let placed=0;\n  while(placed<mines){\n    const i=Math.floor(Math.random()*rows*cols);\n    if(board[i]!==9&&i!==firstIdx){board[i]=9;placed++;}\n  }\n  for(let i=0;i<rows*cols;i++){\n    if(board[i]===9)continue;\n    let count=0;neighbors(i).forEach(n=>{if(board[n]===9)count++;});\n    board[i]=count;\n  }\n}\n\nfunction neighbors(i){\n  const r=Math.floor(i/cols),c=i%cols,ns=[];\n  for(let dr=-1;dr<=1;dr++)for(let dc=-1;dc<=1;dc++){if(dr===0&&dc===0)continue;const nr=r+dr,nc=c+dc;if(nr>=0&&nr<rows&&nc>=0&&nc<cols)ns.push(nr*cols+nc);}\n  return ns;\n}\n\nfunction reveal(i){\n  if(revealed[i]||flagged[i]||gameOver)return;\n  if(firstClick){firstClick=false;placeMines(i);startTimer();}\n  revealed[i]=true;\n  if(board[i]===9){gameOver=true;clearInterval(timer);revealAll();document.getElementById('faceBtn').textContent='😵';document.getElementById('msg').textContent='💥 Boom! Click 😊 to restart';return;}\n  if(board[i]===0)neighbors(i).forEach(n=>reveal(n));\n  if(checkWin()){gameOver=true;clearInterval(timer);document.getElementById('faceBtn').textContent='😎';document.getElementById('msg').textContent='🎉 You won! '+seconds+'s';}\n  renderGrid();\n}\n\nfunction flag(i){\n  if(revealed[i]||gameOver)return;\n  flagged[i]=!flagged[i];\n  const remaining=mines-flagged.filter(Boolean).length;\n  document.getElementById('mineCount').textContent=remaining;\n  renderGrid();\n}\n\nfunction revealAll(){\n  board.forEach((v,i)=>{if(v===9){revealed[i]=true;}});\n  renderGrid();\n}\n\nfunction checkWin(){return board.every((v,i)=>v===9||revealed[i]);}\n\nfunction startTimer(){\n  timer=setInterval(()=>{seconds++;document.getElementById('timerDisp').textContent=seconds;},1000);\n}\n\nfunction renderGrid(){\n  const g=document.getElementById('grid');\n  g.style.gridTemplateColumns=`repeat(${cols},34px)`;\n  g.innerHTML='';\n  board.forEach((v,i)=>{\n    const cell=document.createElement('div');cell.className='cell';\n    if(revealed[i]){\n      cell.classList.add('revealed');\n      if(v===9){cell.textContent='💣';cell.classList.add('mine');}\n      else if(v>0){cell.textContent=v;cell.classList.add('n'+v);}\n    } else if(flagged[i]){\n      cell.textContent='🚩';cell.classList.add('flagged');\n    }\n    // Click\n    cell.addEventListener('click',()=>reveal(i));\n    // Long press for flag\n    let lt=null;\n    cell.addEventListener('touchstart',()=>{lt=setTimeout(()=>{flag(i);lt=null;},400);},{passive:true});\n    cell.addEventListener('touchend',()=>{if(lt){clearTimeout(lt);}},{passive:true});\n    cell.addEventListener('contextmenu',e=>{e.preventDefault();flag(i);});\n    g.appendChild(cell);\n  });\n}\n\nnewGame();\n</script></body></html>"}